---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, author } = Astro.props;
---

<html lang="fr">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="art-hero">
					{heroImage && (
						<div class="art-hero-img" aria-hidden="true">
							<Image src={heroImage} alt="" width={1920} height={900} loading="eager" />
							<div class="art-hero-wash"></div>
						</div>
					)}

					<div class="container art-hero-content">
						<a class="back" href="/blog/">← Tous les articles</a>

						<div class="art-tags">
							{category && (
								<span class="tag tag-cat" data-cat={category}>{category}</span>
							)}
							<span class="tag tag-white">
								<FormattedDate date={pubDate} />
							</span>
							{author && <span class="tag tag-dark">par {author}</span>}
						</div>

						<h1 class="art-title">{title}</h1>

						<p class="art-desc">{description}</p>

						{updatedDate && (
							<p class="updated">
								Dernière mise à jour le <FormattedDate date={updatedDate} />
							</p>
						)}
					</div>
				</header>

				<div class="tfr-stripes" aria-hidden="true"></div>

				<div class="art-body">
					<div class="container">
						<div class="prose">
							<slot />
						</div>

						<footer class="art-footer">
							<a class="btn btn-outline" href="/blog/">← Tous les articles</a>
							<a class="btn btn-primary" href="/">Retour à l'accueil</a>
						</footer>
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<style>
			main { padding-bottom: 2rem; }

			.art-hero {
				position: relative;
				min-height: 52vh;
				display: flex;
				align-items: flex-end;
				padding: 5rem 0 3rem;
				overflow: hidden;
				background: var(--color-cream);
			}

			.art-hero-img {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.art-hero-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.art-hero-wash {
				position: absolute;
				inset: 0;
				background:
					linear-gradient(180deg, rgba(245, 241, 232, 0.25) 0%, rgba(245, 241, 232, 0.9) 100%),
					linear-gradient(90deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.1) 55%);
			}

			.art-hero-content {
				position: relative;
				z-index: 2;
			}

			.back {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--color-gris);
				margin-bottom: 2rem;
				transition: color 0.2s ease;
			}

			.back:hover { color: var(--color-rouge); }

			.art-tags {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}

			.art-title {
				font-size: clamp(2rem, 5.5vw, 4rem);
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: -0.025em;
				line-height: 1.02;
				max-width: 22ch;
				color: var(--color-noir);
				text-shadow: 0 2px 20px rgba(255, 255, 255, 0.5);
			}

			.art-desc {
				margin-top: 1.5rem;
				max-width: 60ch;
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-noir-2);
				background: rgba(255, 255, 255, 0.55);
				padding: 0.4rem 0;
			}

			.updated {
				margin-top: 1.25rem;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-gris);
			}

			.art-body {
				padding: 4rem 0;
				background: var(--color-blanc);
			}

			.art-body .prose {
				max-width: 46rem;
				margin: 0 auto;
			}

			.art-footer {
				margin: 4rem auto 0;
				max-width: 46rem;
				padding-top: 2.5rem;
				border-top: 2px solid var(--color-rouge);
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
