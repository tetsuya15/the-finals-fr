---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, author } = Astro.props;
---

<html lang="fr">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="art-hero">
					{heroImage && (
						<div class="art-hero-img" aria-hidden="true">
							<Image src={heroImage} alt="" width={1920} height={900} loading="eager" />
							<div class="art-hero-overlay"></div>
						</div>
					)}
					<div class="scanlines" aria-hidden="true"></div>

					<div class="container art-hero-content">
						<a class="back" href="/blog/">← Tous les articles</a>

						<div class="art-tags">
							{category && (
								<span class="tag tag-cat" data-cat={category}>{category}</span>
							)}
							<span class="tag tag-white">
								<FormattedDate date={pubDate} />
							</span>
							{author && <span class="tag tag-gold">par {author}</span>}
						</div>

						<h1 class="art-title">{title}</h1>

						<p class="art-desc">{description}</p>

						{updatedDate && (
							<p class="updated">
								Dernière mise à jour le <FormattedDate date={updatedDate} />
							</p>
						)}
					</div>
				</header>

				<div class="art-body">
					<div class="container">
						<div class="prose">
							<slot />
						</div>

						<footer class="art-footer">
							<a class="btn btn-outline" href="/blog/">← Tous les articles</a>
							<a class="btn btn-primary" href="/">Retour à l'accueil</a>
						</footer>
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<style>
			main { padding-bottom: 2rem; }

			.art-hero {
				position: relative;
				min-height: 60vh;
				display: flex;
				align-items: flex-end;
				padding: 5rem 0 3rem;
				overflow: hidden;
				border-bottom: 1px solid rgba(200, 16, 46, 0.25);
			}

			.art-hero-img {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.art-hero-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				filter: grayscale(0.2) contrast(1.05) brightness(0.55);
			}

			.art-hero-overlay {
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 60% 80% at 0% 100%, rgba(200,16,46,0.3), transparent 60%),
					linear-gradient(180deg, rgba(8,8,8,0.4) 0%, rgba(8,8,8,0.88) 100%);
			}

			.scanlines {
				position: absolute;
				inset: 0;
				background: repeating-linear-gradient(
					0deg,
					transparent 0,
					transparent 2px,
					rgba(0, 0, 0, 0.1) 2px,
					rgba(0, 0, 0, 0.1) 4px
				);
				z-index: 2;
				pointer-events: none;
			}

			.art-hero-content {
				position: relative;
				z-index: 3;
			}

			.back {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--color-gris);
				margin-bottom: 2rem;
				transition: color 0.2s ease;
			}

			.back:hover { color: var(--color-or); }

			.art-tags {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}

			.art-title {
				font-size: clamp(2rem, 5.5vw, 4rem);
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: -0.025em;
				line-height: 1.02;
				max-width: 22ch;
				text-shadow: 0 0 40px rgba(0, 0, 0, 0.6);
			}

			.art-desc {
				margin-top: 1.5rem;
				max-width: 60ch;
				font-size: 1.1rem;
				line-height: 1.65;
				color: rgba(240, 234, 214, 0.75);
			}

			.updated {
				margin-top: 1.25rem;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-gris);
			}

			.art-body { padding: 4rem 0; }

			.art-body .prose {
				max-width: 46rem;
				margin: 0 auto;
			}

			.art-footer {
				margin: 4rem auto 0;
				max-width: 46rem;
				padding-top: 2.5rem;
				border-top: 1px solid rgba(200, 16, 46, 0.25);
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
