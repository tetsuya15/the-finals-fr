---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, author } = Astro.props;
---

<html lang="fr">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="article-hero">
					<div class="tfr-container">
						<a class="back" href="/blog/">← Tous les articles</a>

						<div class="meta-row">
							{category && (
								<span class="tfr-badge" data-cat={category}>{category}</span>
							)}
							<span class="date">
								<FormattedDate date={pubDate} />
								{author && <span class="author"> · par {author}</span>}
							</span>
						</div>

						<h1 class="article-title">{title}</h1>

						<p class="article-desc">{description}</p>

						{updatedDate && (
							<p class="updated">
								Dernière mise à jour le <FormattedDate date={updatedDate} />
							</p>
						)}
					</div>
				</header>

				{heroImage && (
					<div class="hero-image">
						<div class="tfr-container">
							<Image width={1280} height={640} src={heroImage} alt="" />
						</div>
					</div>
				)}

				<div class="article-body">
					<div class="tfr-container">
						<div class="prose tfr-prose">
							<slot />
						</div>

						<footer class="article-footer">
							<a class="tfr-arrow" href="/blog/">Tous les articles</a>
							<a class="tfr-arrow" href="/">Retour à l'accueil</a>
						</footer>
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<style>
			main {
				padding-bottom: 2rem;
			}

			.article-hero {
				padding: 3rem 0 2.5rem;
				border-bottom: 1px solid var(--color-border);
				background:
					radial-gradient(ellipse 40% 60% at 0% 0%, color-mix(in oklab, var(--color-accent) 5%, transparent), transparent 60%);
			}

			.back {
				display: inline-block;
				font-family: var(--font-display);
				font-size: 0.75rem;
				font-weight: 600;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--color-text-dim);
				margin-bottom: 2rem;
				transition: color 0.15s ease;
			}

			.back:hover {
				color: var(--color-accent);
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1.5rem;
			}

			.meta-row .date {
				font-family: var(--font-display);
				font-size: 0.78rem;
				font-weight: 500;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-text-dim);
			}

			.meta-row .author {
				color: var(--color-text-muted);
			}

			.article-title {
				font-size: clamp(2rem, 5vw, 3.75rem);
				text-transform: uppercase;
				letter-spacing: -0.025em;
				line-height: 1.02;
				max-width: 22ch;
			}

			.article-desc {
				margin-top: 1.5rem;
				max-width: 60ch;
				font-size: 1.1rem;
				line-height: 1.65;
				color: var(--color-text-muted);
			}

			.updated {
				margin-top: 1.5rem;
				font-family: var(--font-display);
				font-size: 0.72rem;
				font-weight: 500;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-text-dim);
			}

			.hero-image {
				padding: 2.5rem 0 0;
			}

			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border: 1px solid var(--color-border);
			}

			.article-body {
				padding: 3rem 0;
			}

			.prose {
				max-width: 44rem;
				margin: 0 auto;
			}

			.article-footer {
				margin: 4rem auto 0;
				max-width: 44rem;
				padding-top: 2rem;
				border-top: 1px solid var(--color-border);
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
