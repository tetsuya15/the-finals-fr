---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { NAV_SECTIONS, SITE_TITLE } from '../consts';

import catMeta from '../assets/cat-meta-v3.jpg';
import catEsport from '../assets/T_UI_S8_MainMenu_BKG.webp';
import catWiki from '../assets/cat-wiki-v3.jpg';
import catActus from '../assets/cat-actus-v2.jpg';
import wikiClasses from '../assets/cat-lore.jpg';
import wikiMaps from '../assets/the-finals-monaco-map.jpg';
import wikiWeapons from '../assets/The-Finals-Season-8-header.jpg';
import wikiGadgets from '../assets/SEASON-9-LAUNCH-TRAILER-_-THE-FINALS-0-45-screenshot.webp';

const CAT_IMG = {
	communaute: catMeta,
	esport: catEsport,
	wiki: catWiki,
	actus: catActus,
};

export async function getStaticPaths() {
	return NAV_SECTIONS.map((s) => ({ params: { category: s.slug } }));
}

const { category } = Astro.params;
const section = NAV_SECTIONS.find((s) => s.slug === category)!;
const label = section.label;
const schemaCategory = category === 'communaute' ? 'Meta' : label;
const headerImage = CAT_IMG[category as keyof typeof CAT_IMG];

const posts = (await getCollection('blog'))
	.filter((p) => p.data.category === schemaCategory)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const splitChars = (text: string) => Array.from(text);
const sectionLabelText = `${SITE_TITLE} — Catégorie`;
const titleText = label;
const taglineText = section.tagline;
const wikiCards = [
	{
		id: 'maps',
		title: 'Les Maps',
		description: 'Callouts, rotations, lignes de vue et points chauds des cartes.',
		image: wikiMaps,
		href: '/blog/les-maps-the-finals/',
	},
	{
		id: 'classes',
		title: 'Les classes',
		description: 'Forces, faiblesses, gadgets et synergies Light, Medium, Heavy.',
		image: wikiClasses,
		href: '/blog/les-classes-the-finals/',
	},
	{
		id: 'armes',
		title: 'Les armes',
		description: 'Stats, recoil, portee utile et builds armes selon ton style de jeu.',
		image: wikiWeapons,
		href: '/blog/les-armes-the-finals/',
	},
	{
		id: 'gadgets',
		title: 'Les gadgets',
		description: 'Utilite, timings et combos de gadgets pour prendre l avantage en teamplay.',
		image: wikiGadgets,
		href: '/blog/les-gadgets-the-finals/',
	},
];
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`${section.label} — ${SITE_TITLE}`}
			description={section.description}
			image={headerImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="cat-hero">
				<div class="cat-hero-img" data-slug={category} aria-hidden="true">
					<Image
						src={headerImage}
						alt=""
						width={1920}
						height={1080}
						densities={[1, 2]}
						quality={92}
						loading="eager"
						sizes="100vw"
					/>
					<div class="cat-hero-wash"></div>
				</div>

				<div class="container cat-hero-content">
					<div class="section-label">
						<span class="split-line" aria-label={sectionLabelText} style="--base: 0s">
							{splitChars(sectionLabelText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</div>

					<h1 class="cat-title" data-cat={label}>
						<span class="split-line" aria-label={titleText} style="--base: 0.45s">
							{splitChars(titleText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</h1>

					<p class="cat-tagline">
						<span class="split-line" aria-label={taglineText} style="--base: 0.85s">
							{splitChars(taglineText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</p>

					<p class="cat-desc">{section.description}</p>
					<div class="cat-meta">
						<span class="tag tag-cat" data-cat={label}>{label}</span>
						<span class="cat-count">
							{posts.length === 0
								? '· Section bientôt disponible'
								: `· ${posts.length} article${posts.length > 1 ? 's' : ''} publié${posts.length > 1 ? 's' : ''}`}
						</span>
					</div>
				</div>
			</section>

			<div class="tfr-stripes" aria-hidden="true"></div>

			{category === 'wiki' && (
				<section class="wiki-sections">
					<div class="container">
						<div class="section-label">Wiki — Sections clés</div>
						<h2 class="wiki-title">
							Maps, classes et armes<br />
							<em>en un coup d'oeil.</em>
						</h2>

						<div class="wiki-expand-track" role="region" aria-label="Sections Wiki">
							{wikiCards.map((card) => (
								<a class="wiki-expand-card card" data-slide={card.id} href={card.href}>
									<div class="wiki-card-img">
										<Image src={card.image} alt={card.title} width={1280} height={720} loading="lazy" />
										<div class="wiki-card-wash"></div>
									</div>
									<div class="wiki-card-body">
										<h3>{card.title}</h3>
										<p>{card.description}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}

			{category !== 'wiki' && (
				<section class="cat-list">
					<div class="container">
						{posts.length === 0 ? (
						<div class="empty card">
							<div class="section-label">Bientôt — En production</div>
							<h2 class="empty-title">
								Cette section<br />
								<em>arrive bientôt.</em>
							</h2>
							<p class="empty-text">
								Les premiers contenus <strong>{label}</strong> sont en préparation.
								Les articles arriveront d'ici quelques jours.
							</p>
							<div class="empty-tags">
								<span class="tag tag-red">En cours</span>
								<span class="tag tag-dark">Bientôt</span>
								<span class="tag tag-white">Reviens plus tard</span>
							</div>
							<a class="btn btn-outline" href="/" style="margin-top: 2rem;">
								← Retour à l'accueil
							</a>
						</div>
						) : (
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a class="post card" href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<div class="post-img">
												<Image
													src={post.data.heroImage}
													alt=""
													width={480}
													height={270}
													loading="lazy"
												/>
											</div>
										)}
										<div class="post-body">
											<div class="post-tags">
												<span class="tag tag-cat" data-cat={post.data.category ?? label}>
													{post.data.category ?? label}
												</span>
											</div>
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<div class="post-meta">
												<FormattedDate date={post.data.pubDate} />
												{post.data.author && <span>· par {post.data.author}</span>}
											</div>
										</div>
									</a>
								</li>
							))}
						</ul>
						)}
					</div>
				</section>
			)}
		</main>
		<Footer />
		<style>
			main { padding-bottom: 2rem; }

			/* Per-line base delay so the 3 hero text elements cascade sequentially
			   (label -> title -> tagline), matching the split-letter reveal used
			   on the homepage hero. */
			.cat-hero-content .split-char {
				animation-delay: calc(var(--base, 0s) + 0.04s * var(--i, 0));
			}

			/* ============ HERO CATÉGORIE ============ */
			.cat-hero {
				position: relative;
				min-height: 48vh;
				display: flex;
				align-items: flex-end;
				padding: 5rem 0 3.5rem;
				overflow: hidden;
				background: var(--color-cream);
			}

			.cat-hero-img {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.cat-hero-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			/* Wiki uniquement: cadrage centré pour équilibrer perso à gauche + pièces à droite */
			.cat-hero-img[data-slug='wiki'] :global(img) {
				object-position: center center;
			}

			/* Communaute uniquement: descend le cadrage pour voir le visage masque entier */
			.cat-hero-img[data-slug='communaute'] :global(img) {
				object-position: center 24%;
			}

			.cat-hero-wash {
				position: absolute;
				inset: 0;
				background:
					linear-gradient(180deg, rgba(245, 241, 232, 0.05) 0%, rgba(245, 241, 232, 0.55) 100%),
					linear-gradient(90deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.02) 55%);
			}

			.cat-hero-content {
				position: relative;
				z-index: 2;
			}

			.cat-title {
				font-size: clamp(3.5rem, 11vw, 7.5rem);
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: -0.03em;
				line-height: 0.9;
				margin: 0.8rem 0 0;
				color: var(--color-noir);
				text-shadow: none;
			}

			.cat-tagline {
				font-family: var(--font-display);
				font-size: clamp(1.1rem, 2vw, 1.5rem);
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: var(--color-rouge);
				margin-top: 1.2rem;
				text-shadow: 0 2px 16px rgba(255, 255, 255, 0.6);
			}

			.cat-desc {
				margin-top: 1rem;
				max-width: 60ch;
				font-size: 1rem;
				color: var(--color-noir-2);
				line-height: 1.65;
				background: rgba(255, 255, 255, 0.75);
				padding: 0.5rem 0.8rem;
				border-left: 2px solid var(--color-rouge);
			}

			.cat-meta {
				margin-top: 1.5rem;
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.cat-count {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-gris);
			}

			/* ============ LISTE ============ */
			.cat-list {
				padding: 4rem 0;
			}

			/* ============ WIKI SECTIONS (animated carousel) ============ */
			.wiki-sections {
				padding: 4rem 0 1rem;
				background: var(--color-blanc);
			}

			.wiki-title {
				margin-top: 0.8rem;
				margin-bottom: 1.3rem;
				font-size: clamp(1.8rem, 5vw, 3rem);
				line-height: 1.02;
				text-transform: uppercase;
				color: var(--color-noir);
			}

			.wiki-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.wiki-expand-track {
				display: flex;
				gap: 1rem;
				align-items: stretch;
			}

			.wiki-expand-card {
				flex: 0.45;
				min-width: 0;
				height: 38rem;
				overflow: hidden;
				text-decoration: none;
				transition:
					flex 0.48s cubic-bezier(0.25, 1, 0.5, 1),
					transform 0.32s cubic-bezier(0.25, 1, 0.5, 1),
					box-shadow 0.32s ease;
			}

			.wiki-expand-track:hover .wiki-expand-card {
				flex: 0.32;
			}

			.wiki-expand-track .wiki-expand-card:hover {
				flex: 3.4;
				transform: translateY(-4px);
				box-shadow: 0 16px 32px -20px rgba(0, 0, 0, 0.45);
			}

			.wiki-card-img {
				position: relative;
				height: 100%;
				overflow: hidden;
				background: #0b0b0b;
			}

			.wiki-card-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				transition: transform 0.38s ease, filter 0.32s ease;
			}

			.wiki-expand-track:hover .wiki-expand-card .wiki-card-img :global(img) {
				filter: saturate(0.82) brightness(0.9);
			}

			.wiki-expand-track .wiki-expand-card:hover .wiki-card-img :global(img) {
				transform: scale(1.04);
				filter: saturate(1.05) brightness(1);
			}

			.wiki-card-wash {
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.35));
			}

			.wiki-card-body {
				position: absolute;
				left: 0;
				right: 0;
				bottom: 0;
				padding: 1.1rem 1rem 1.2rem;
				color: var(--color-blanc);
				text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
				transition: transform 0.32s ease, opacity 0.24s ease;
			}

			.wiki-card-body h3 {
				margin-top: 0.7rem;
				font-family: var(--font-display);
				font-size: 1.25rem;
				font-weight: 800;
				text-transform: uppercase;
				color: var(--color-blanc);
				letter-spacing: 0.02em;
				line-height: 1.15;
			}

			.wiki-card-body p {
				margin-top: 0.6rem;
				color: rgba(255, 255, 255, 0.9);
				font-size: 0.93rem;
				line-height: 1.6;
			}

			.wiki-expand-track:hover .wiki-expand-card .wiki-card-body {
				opacity: 0.66;
				transform: translateY(8px);
			}

			.wiki-expand-track:hover .wiki-expand-card:hover .wiki-card-body {
				opacity: 1;
				transform: translateY(0);
			}

			@media (max-width: 1023px) {
				.wiki-expand-track {
					flex-direction: column;
				}
				.wiki-expand-card,
				.wiki-expand-track:hover .wiki-expand-card,
				.wiki-expand-track .wiki-expand-card:hover {
					flex: 1;
					height: 28rem;
				}
			}

			.empty {
				max-width: 46rem;
				padding: 3rem 2rem;
				text-align: left;
				background: var(--color-blanc);
			}

			.empty-title {
				font-size: clamp(2.2rem, 5vw, 3.5rem);
				margin: 1rem 0 1.2rem;
				text-transform: uppercase;
				line-height: 1;
				color: var(--color-noir);
			}

			.empty-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.empty-text {
				color: var(--color-noir-2);
				font-size: 1rem;
				line-height: 1.7;
				max-width: 48rem;
			}

			.empty-text strong { color: var(--color-rouge); }

			.empty-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}

			.posts {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.2rem;
			}

			@media (min-width: 768px) {
				.posts { grid-template-columns: repeat(2, 1fr); }
			}

			@media (min-width: 1024px) {
				.posts { grid-template-columns: repeat(3, 1fr); }
			}

			.post {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				overflow: hidden;
				background: var(--color-blanc);
			}

			.post-img {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--color-cream-2);
			}

			.post-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.post:hover .post-img :global(img) { transform: scale(1.05); }

			.post-body {
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.post-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.9rem;
			}

			.post-body h3 {
				font-family: var(--font-display);
				font-size: 1.4rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				line-height: 1.15;
				color: var(--color-noir);
				margin-bottom: 0.7rem;
				transition: color 0.2s ease;
			}

			.post:hover .post-body h3 { color: var(--color-rouge); }

			.post-body p {
				color: var(--color-noir-2);
				font-size: 0.92rem;
				line-height: 1.55;
				margin-bottom: 1rem;
				flex-grow: 1;
			}

			.post-meta {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--color-gris);
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
