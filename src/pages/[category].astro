---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { NAV_SECTIONS, SITE_TITLE } from '../consts';

import catMeta from '../assets/cat-meta-v3.jpg';
import catEsport from '../assets/T_UI_S8_MainMenu_BKG.webp';
import catWiki from '../assets/cat-wiki-v3.jpg';
import catActus from '../assets/cat-actus-v2.jpg';
import wikiClasses from '../assets/cat-lore.jpg';
import wikiMaps from '../assets/the-finals-monaco-map.jpg';
import wikiWeapons from '../assets/The-Finals-Season-8-header.jpg';
import wikiGadgets from '../assets/SEASON-9-LAUNCH-TRAILER-_-THE-FINALS-0-45-screenshot.webp';
import { ESPORT_TEAM_LOCAL_LOGOS } from '../data/esportTeamLogoImports';
import { ESPORT_TEAMS } from '../data/esportTeams';

const CAT_IMG = {
	communaute: catMeta,
	esport: catEsport,
	wiki: catWiki,
	actus: catActus,
};

export async function getStaticPaths() {
	return NAV_SECTIONS.map((s) => ({ params: { category: s.slug } }));
}

const { category } = Astro.params;
const section = NAV_SECTIONS.find((s) => s.slug === category)!;
const label = section.label;
const schemaCategory = category === 'communaute' ? 'Meta' : label;
const headerImage = CAT_IMG[category as keyof typeof CAT_IMG];

const posts = (await getCollection('blog'))
	.filter((p) => p.data.category === schemaCategory)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const splitChars = (text: string) => Array.from(text);
const sectionLabelText = `${SITE_TITLE} — Catégorie`;
const titleText = label;
const taglineText = section.tagline;
const wikiCards = [
	{
		id: 'maps',
		title: 'Les Maps',
		description: 'Callouts, rotations, lignes de vue et points chauds des cartes.',
		image: wikiMaps,
		href: '/blog/les-maps-the-finals/',
	},
	{
		id: 'classes',
		title: 'Les classes',
		description: 'Forces, faiblesses, gadgets et synergies Light, Medium, Heavy.',
		image: wikiClasses,
		href: '/blog/les-classes-the-finals/',
	},
	{
		id: 'armes',
		title: 'Les armes',
		description: 'Stats, recoil, portee utile et builds armes selon ton style de jeu.',
		image: wikiWeapons,
		href: '/blog/les-armes-the-finals/',
	},
	{
		id: 'gadgets',
		title: 'Les gadgets',
		description: 'Utilite, timings et combos de gadgets pour prendre l avantage en teamplay.',
		image: wikiGadgets,
		href: '/blog/les-gadgets-the-finals/',
	},
];
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`${section.label} — ${SITE_TITLE}`}
			description={section.description}
			image={headerImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="cat-hero">
				<div class="cat-hero-img" data-slug={category} aria-hidden="true">
					<Image
						src={headerImage}
						alt=""
						width={1920}
						height={1080}
						densities={[1, 2]}
						quality={92}
						loading="eager"
						sizes="100vw"
					/>
					<div class="cat-hero-wash"></div>
				</div>

				<div class="container cat-hero-content">
					<div class="section-label">
						<span class="split-line" aria-label={sectionLabelText} style="--base: 0s">
							{splitChars(sectionLabelText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</div>

					<h1 class="cat-title" data-cat={label}>
						<span class="split-line" aria-label={titleText} style="--base: 0.45s">
							{splitChars(titleText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</h1>

					<p class="cat-tagline">
						<span class="split-line" aria-label={taglineText} style="--base: 0.85s">
							{splitChars(taglineText).map((ch, i) => (
								<span
									class={'split-char' + (ch === ' ' ? ' space' : '')}
									style={`--i: ${i}`}
									aria-hidden="true"
								>{ch === ' ' ? '\u00A0' : ch}</span>
							))}
						</span>
					</p>

					<p class="cat-desc">{section.description}</p>
					<div class="cat-meta">
						<span class="tag tag-cat" data-cat={label}>{label}</span>
						<span class="cat-count">
							{posts.length === 0
								? '· Section bientôt disponible'
								: `· ${posts.length} article${posts.length > 1 ? 's' : ''} publié${posts.length > 1 ? 's' : ''}`}
						</span>
					</div>
				</div>
			</section>

			<div class="tfr-stripes" aria-hidden="true"></div>

			{category === 'wiki' && (
				<section class="wiki-sections">
					<div class="container">
						<div class="section-label">Wiki — Sections clés</div>
						<h2 class="wiki-title">
							Maps, classes et armes<br />
							<em>en un coup d'oeil.</em>
						</h2>

						<div class="wiki-expand-track" role="region" aria-label="Sections Wiki">
							{wikiCards.map((card) => (
								<a class="wiki-expand-card card" data-slide={card.id} href={card.href}>
									<div class="wiki-card-img">
										<Image src={card.image} alt={card.title} width={1280} height={720} loading="lazy" />
										<div class="wiki-card-wash"></div>
									</div>
									<div class="wiki-card-body">
										<h3>{card.title}</h3>
										<p>{card.description}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}

			{category === 'esport' && (
				<section class="esport-sections">
					<div class="container">
						<div class="section-label">Esport — Teams majeurs</div>
						<h2 class="esport-title">
							Les équipes du circuit<br />
							<em>Grand Major & suites.</em>
						</h2>
						<p class="esport-intro">
							Cette page regroupe les principales <strong>équipes e-sport de THE FINALS</strong> dans un format
							“team card” : identité de la structure, résultats marquants et <strong>roster</strong> connu.
							L’objectif est d’avoir une vue rapide de la scène compétitive, avec pour chaque équipe une fiche lisible
							centrée sur l’effectif et les performances récentes.
						</p>

						<div class="esport-team-grid">
							{ESPORT_TEAMS.map((team) => (
								<article class="esport-team-card card">
									<div
										class="esport-team-visual"
										data-bundle={ESPORT_TEAM_LOCAL_LOGOS[team.id] ? 'true' : undefined}
									>
										{ESPORT_TEAM_LOCAL_LOGOS[team.id] ? (
											<Image
												src={ESPORT_TEAM_LOCAL_LOGOS[team.id]!}
												alt={`Visuel ${team.name}`}
												width={800}
												height={450}
												loading="lazy"
												quality={85}
											/>
										) : (
											<img
												src={team.logoUrl}
												alt={`Logo ${team.name}`}
												loading="lazy"
												decoding="async"
												width={600}
												height={300}
											/>
										)}
										<div class="esport-pb" aria-hidden="true">
											<div class="esport-pb-layer" data-i="0"></div>
											<div class="esport-pb-layer" data-i="1"></div>
											<div class="esport-pb-layer" data-i="2"></div>
											<div class="esport-pb-layer" data-i="3"></div>
										</div>
										<div class="esport-pb-meta">
											<span class="esport-pb-tag">{team.region}</span>
											<p class="esport-pb-title">{team.name}</p>
											<span class="esport-pb-desc">{team.palmares[0]}</span>
										</div>
									</div>

									<div class="esport-team-body">
									<div class="esport-team-head">
										<h3>{team.name}</h3>
										<span class="esport-region">{team.region}</span>
									</div>

									<h4 class="esport-subhead">Palmarès (extraits)</h4>
									<ul class="esport-palmares">
										{team.palmares.map((line) => (
											<li>{line}</li>
										))}
									</ul>

									{team.rosterActive && team.rosterActive.length > 0 && (
										<>
											<h4 class="esport-subhead">Roster actuel</h4>
											<ul class="esport-roster">
												{team.rosterActive.map((p) => (
													<li>
														<strong>{p.nick}</strong>
														{p.realName && <span class="esport-real"> — {p.realName}</span>}
														{p.note && <span class="esport-note"> ({p.note})</span>}
													</li>
												))}
											</ul>
											{team.staff && team.staff.length > 0 && (
												<ul class="esport-staff">
													{team.staff.map((s) => (
														<li>
															<span class="esport-staff-role">{s.role}</span> · {s.nick}
														</li>
													))}
												</ul>
											)}
										</>
									)}

									{team.gm2025Roster && team.gm2025Roster.length > 0 && (
										<>
											<h4 class="esport-subhead">Grand Major 2025 — roster LAN</h4>
											<ul class="esport-roster esport-roster-muted">
												{team.gm2025Roster.map((p) => (
													<li>
														<strong>{p.nick}</strong>
														{p.realName && <span class="esport-real"> — {p.realName}</span>}
													</li>
												))}
											</ul>
											{team.gm2025Staff && team.gm2025Staff.length > 0 && (
												<ul class="esport-staff esport-staff-muted">
													{team.gm2025Staff.map((s) => (
														<li>
															<span class="esport-staff-role">{s.role}</span> · {s.nick}
														</li>
													))}
												</ul>
											)}
										</>
									)}

									{team.footnote && <p class="esport-footnote">{team.footnote}</p>}

									<a class="esport-liquipedia" href={team.liquipediaUrl} target="_blank" rel="noopener noreferrer">
										Fiche Liquipedia →
									</a>
									</div>
								</article>
							))}
						</div>

					</div>
				</section>
			)}

			{category !== 'wiki' && (
				<section class="cat-list">
					<div class="container">
						{posts.length === 0 ? (
							category === 'esport' ? null : (
						<div class="empty card">
							<div class="section-label">Bientôt — En production</div>
							<h2 class="empty-title">
								Cette section<br />
								<em>arrive bientôt.</em>
							</h2>
							<p class="empty-text">
								Les premiers contenus <strong>{label}</strong> sont en préparation.
								Les articles arriveront d'ici quelques jours.
							</p>
							<div class="empty-tags">
								<span class="tag tag-red">En cours</span>
								<span class="tag tag-dark">Bientôt</span>
								<span class="tag tag-white">Reviens plus tard</span>
							</div>
							<a class="btn btn-outline" href="/" style="margin-top: 2rem;">
								← Retour à l'accueil
							</a>
						</div>
							)
						) : (
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a class="post card" href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<div class="post-img">
												<Image
													src={post.data.heroImage}
													alt=""
													width={480}
													height={270}
													loading="lazy"
												/>
											</div>
										)}
										<div class="post-body">
											<div class="post-tags">
												<span class="tag tag-cat" data-cat={post.data.category ?? label}>
													{post.data.category ?? label}
												</span>
											</div>
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<div class="post-meta">
												<FormattedDate date={post.data.pubDate} />
												{post.data.author && <span>· par {post.data.author}</span>}
											</div>
										</div>
									</a>
								</li>
							))}
						</ul>
						)}
					</div>
				</section>
			)}
		</main>
		<Footer />
		<style>
			main { padding-bottom: 2rem; }

			/* Per-line base delay so the 3 hero text elements cascade sequentially
			   (label -> title -> tagline), matching the split-letter reveal used
			   on the homepage hero. */
			.cat-hero-content .split-char {
				animation-delay: calc(var(--base, 0s) + 0.04s * var(--i, 0));
			}

			/* ============ HERO CATÉGORIE ============ */
			.cat-hero {
				position: relative;
				min-height: 48vh;
				display: flex;
				align-items: flex-end;
				padding: 5rem 0 3.5rem;
				overflow: hidden;
				background: var(--color-cream);
			}

			.cat-hero-img {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.cat-hero-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			/* Wiki uniquement: cadrage centré pour équilibrer perso à gauche + pièces à droite */
			.cat-hero-img[data-slug='wiki'] :global(img) {
				object-position: center center;
			}

			/* Communaute uniquement: descend le cadrage pour voir le visage masque entier */
			.cat-hero-img[data-slug='communaute'] :global(img) {
				object-position: center 24%;
			}

			.cat-hero-wash {
				position: absolute;
				inset: 0;
				background:
					linear-gradient(180deg, rgba(245, 241, 232, 0.05) 0%, rgba(245, 241, 232, 0.55) 100%),
					linear-gradient(90deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.02) 55%);
			}

			.cat-hero-content {
				position: relative;
				z-index: 2;
			}

			.cat-title {
				font-size: clamp(3.5rem, 11vw, 7.5rem);
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: -0.03em;
				line-height: 0.9;
				margin: 0.8rem 0 0;
				color: var(--color-noir);
				text-shadow: none;
			}

			.cat-tagline {
				font-family: var(--font-display);
				font-size: clamp(1.1rem, 2vw, 1.5rem);
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: var(--color-rouge);
				margin-top: 1.2rem;
				text-shadow: 0 2px 16px rgba(255, 255, 255, 0.6);
			}

			.cat-desc {
				margin-top: 1rem;
				max-width: 60ch;
				font-size: 1rem;
				color: var(--color-noir-2);
				line-height: 1.65;
				background: rgba(255, 255, 255, 0.75);
				padding: 0.5rem 0.8rem;
				border-left: 2px solid var(--color-rouge);
			}

			.cat-meta {
				margin-top: 1.5rem;
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.cat-count {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-gris);
			}

			/* ============ LISTE ============ */
			.cat-list {
				padding: 4rem 0;
			}

			/* ============ WIKI SECTIONS (animated carousel) ============ */
			.wiki-sections {
				padding: 4rem 0 1rem;
				background: var(--color-blanc);
			}

			.wiki-title {
				margin-top: 0.8rem;
				margin-bottom: 1.3rem;
				font-size: clamp(1.8rem, 5vw, 3rem);
				line-height: 1.02;
				text-transform: uppercase;
				color: var(--color-noir);
			}

			.wiki-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.wiki-expand-track {
				display: flex;
				gap: 1rem;
				align-items: stretch;
			}

			.wiki-expand-card {
				flex: 0.45;
				min-width: 0;
				height: 38rem;
				overflow: hidden;
				text-decoration: none;
				transition:
					flex 0.48s cubic-bezier(0.25, 1, 0.5, 1),
					transform 0.32s cubic-bezier(0.25, 1, 0.5, 1),
					box-shadow 0.32s ease;
			}

			.wiki-expand-track:hover .wiki-expand-card {
				flex: 0.32;
			}

			.wiki-expand-track .wiki-expand-card:hover {
				flex: 3.4;
				transform: translateY(-4px);
				box-shadow: 0 16px 32px -20px rgba(0, 0, 0, 0.45);
			}

			.wiki-card-img {
				position: relative;
				height: 100%;
				overflow: hidden;
				background: #0b0b0b;
			}

			.wiki-card-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				transition: transform 0.38s ease, filter 0.32s ease;
			}

			.wiki-expand-track:hover .wiki-expand-card .wiki-card-img :global(img) {
				filter: saturate(0.82) brightness(0.9);
			}

			.wiki-expand-track .wiki-expand-card:hover .wiki-card-img :global(img) {
				transform: scale(1.04);
				filter: saturate(1.05) brightness(1);
			}

			.wiki-card-wash {
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.35));
			}

			.wiki-card-body {
				position: absolute;
				left: 0;
				right: 0;
				bottom: 0;
				padding: 1.1rem 1rem 1.2rem;
				color: var(--color-blanc);
				text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
				transition: transform 0.32s ease, opacity 0.24s ease;
			}

			.wiki-card-body h3 {
				margin-top: 0.7rem;
				font-family: var(--font-display);
				font-size: 1.25rem;
				font-weight: 800;
				text-transform: uppercase;
				color: var(--color-blanc);
				letter-spacing: 0.02em;
				line-height: 1.15;
			}

			.wiki-card-body p {
				margin-top: 0.6rem;
				color: rgba(255, 255, 255, 0.9);
				font-size: 0.93rem;
				line-height: 1.6;
			}

			.wiki-expand-track:hover .wiki-expand-card .wiki-card-body {
				opacity: 0.66;
				transform: translateY(8px);
			}

			.wiki-expand-track:hover .wiki-expand-card:hover .wiki-card-body {
				opacity: 1;
				transform: translateY(0);
			}

			@media (max-width: 1023px) {
				.wiki-expand-track {
					flex-direction: column;
				}
				.wiki-expand-card,
				.wiki-expand-track:hover .wiki-expand-card,
				.wiki-expand-track .wiki-expand-card:hover {
					flex: 1;
					height: 28rem;
				}
			}

			.empty {
				max-width: 46rem;
				padding: 3rem 2rem;
				text-align: left;
				background: var(--color-blanc);
			}

			.empty-title {
				font-size: clamp(2.2rem, 5vw, 3.5rem);
				margin: 1rem 0 1.2rem;
				text-transform: uppercase;
				line-height: 1;
				color: var(--color-noir);
			}

			.empty-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.empty-text {
				color: var(--color-noir-2);
				font-size: 1rem;
				line-height: 1.7;
				max-width: 48rem;
			}

			.empty-text strong { color: var(--color-rouge); }

			.empty-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}

			.posts {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.2rem;
			}

			@media (min-width: 768px) {
				.posts { grid-template-columns: repeat(2, 1fr); }
			}

			@media (min-width: 1024px) {
				.posts { grid-template-columns: repeat(3, 1fr); }
			}

			.post {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				overflow: hidden;
				background: var(--color-blanc);
			}

			.post-img {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--color-cream-2);
			}

			.post-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.post:hover .post-img :global(img) { transform: scale(1.05); }

			.post-body {
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.post-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.9rem;
			}

			.post-body h3 {
				font-family: var(--font-display);
				font-size: 1.4rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				line-height: 1.15;
				color: var(--color-noir);
				margin-bottom: 0.7rem;
				transition: color 0.2s ease;
			}

			.post:hover .post-body h3 { color: var(--color-rouge); }

			.post-body p {
				color: var(--color-noir-2);
				font-size: 0.92rem;
				line-height: 1.55;
				margin-bottom: 1rem;
				flex-grow: 1;
			}

			.post-meta {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--color-gris);
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
			}

			/* ============ ESPORT TEAMS (wiki-inspired layout) ============ */
			.esport-sections {
				padding: 4rem 0 2rem;
				background: var(--color-blanc);
			}

			.esport-title {
				margin-top: 0.8rem;
				margin-bottom: 1rem;
				font-size: clamp(1.8rem, 5vw, 3rem);
				line-height: 1.02;
				text-transform: uppercase;
				color: var(--color-noir);
			}

			.esport-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.esport-intro {
				max-width: 72ch;
				font-size: 1rem;
				line-height: 1.65;
				color: var(--color-noir-2);
				margin-bottom: 2rem;
			}

			.esport-team-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.25rem;
			}

			@media (min-width: 768px) {
				.esport-team-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (min-width: 1200px) {
				.esport-team-grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			.esport-team-card {
				display: flex;
				flex-direction: column;
				align-items: stretch;
				padding: 0;
				overflow: hidden;
				background: var(--color-blanc);
				min-height: 100%;
				isolation: isolate;
			}

			.esport-team-body {
				display: flex;
				flex-direction: column;
				flex: 1;
				align-items: stretch;
				padding: 1.35rem 1.4rem 1.5rem;
			}

			/* Bandeau logo — même principe que les cartes « Les Maps » (blur progressif au survol) */
			.esport-team-visual {
				position: relative;
				height: 11.5rem;
				min-height: 11.5rem;
				flex-shrink: 0;
				overflow: hidden;
				background: #0a0a0a;
			}

			.esport-team-visual img,
			.esport-team-visual :global(img) {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: contain;
				object-position: center;
				padding: 0.85rem 1rem;
				box-sizing: border-box;
				display: block;
				transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
			}

			.esport-team-visual[data-bundle] img,
			.esport-team-visual[data-bundle] :global(img) {
				object-fit: cover;
				padding: 0;
			}

			.esport-team-card:hover .esport-team-visual img,
			.esport-team-card:hover .esport-team-visual :global(img) {
				transform: scale(1.04);
			}

			.esport-pb {
				position: absolute;
				left: 0;
				bottom: 0;
				width: 100%;
				height: 78%;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.25s ease-out;
			}

			.esport-team-card:hover .esport-pb {
				opacity: 1;
			}

			.esport-pb-layer {
				position: absolute;
				inset: 0;
				pointer-events: none;
				border-radius: inherit;
			}

			.esport-pb-layer[data-i='0'] {
				backdrop-filter: blur(1px);
				-webkit-backdrop-filter: blur(1px);
				-webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 20%, #000 40%, transparent 60%);
				mask-image: linear-gradient(180deg, transparent 0%, #000 20%, #000 40%, transparent 60%);
			}

			.esport-pb-layer[data-i='1'] {
				backdrop-filter: blur(3px);
				-webkit-backdrop-filter: blur(3px);
				-webkit-mask-image: linear-gradient(180deg, transparent 20%, #000 40%, #000 60%, transparent 80%);
				mask-image: linear-gradient(180deg, transparent 20%, #000 40%, #000 60%, transparent 80%);
			}

			.esport-pb-layer[data-i='2'] {
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				-webkit-mask-image: linear-gradient(180deg, transparent 40%, #000 60%, #000 80%, transparent 100%);
				mask-image: linear-gradient(180deg, transparent 40%, #000 60%, #000 80%, transparent 100%);
			}

			.esport-pb-layer[data-i='3'] {
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				-webkit-mask-image: linear-gradient(180deg, transparent 60%, #000 80%, #000 100%);
				mask-image: linear-gradient(180deg, transparent 60%, #000 80%, #000 100%);
			}

			.esport-pb-meta {
				position: absolute;
				left: 0;
				right: 0;
				bottom: 0;
				padding: 0.75rem 1rem 0.95rem;
				color: #fff;
				opacity: 0;
				transform: translateY(8px);
				transition: opacity 0.25s ease-out, transform 0.3s ease-out;
				pointer-events: none;
			}

			.esport-team-card:hover .esport-pb-meta {
				opacity: 1;
				transform: translateY(0);
			}

			.esport-pb-tag {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.62rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: #fff;
				background: var(--color-rouge);
				padding: 0.2rem 0.45rem;
				border-radius: 0.2rem;
				max-width: 100%;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				vertical-align: top;
			}

			.esport-pb-title {
				margin: 0.35rem 0 0.35rem;
				font-family: var(--font-display);
				font-size: 1.05rem;
				font-weight: 800;
				letter-spacing: 0.02em;
				text-transform: uppercase;
				line-height: 1.12;
				text-shadow: 0 2px 12px rgba(0, 0, 0, 0.75);
			}

			.esport-pb-desc {
				margin: 0;
				font-size: 0.78rem;
				line-height: 1.45;
				color: rgba(255, 255, 255, 0.94);
				text-shadow: 0 2px 10px rgba(0, 0, 0, 0.72);
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			@media (hover: none) {
				.esport-pb {
					opacity: 1;
				}

				.esport-pb-meta {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.esport-pb,
				.esport-pb-meta,
				.esport-team-visual img,
				.esport-team-visual :global(img) {
					transition: none;
				}

				.esport-team-card:hover .esport-team-visual img,
				.esport-team-card:hover .esport-team-visual :global(img) {
					transform: none;
				}
			}

			.esport-team-head h3 {
				font-family: var(--font-display);
				font-size: 1.35rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				line-height: 1.15;
				margin: 0 0 0.35rem;
				color: var(--color-noir);
			}

			.esport-region {
				display: block;
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--color-gris);
				line-height: 1.35;
			}

			.esport-subhead {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--color-rouge);
				margin: 1rem 0 0.45rem;
				font-weight: 700;
			}

			.esport-palmares,
			.esport-roster,
			.esport-staff {
				list-style: none;
				padding: 0;
				margin: 0;
				font-size: 0.88rem;
				line-height: 1.55;
				color: var(--color-noir-2);
			}

			.esport-palmares li {
				position: relative;
				padding-left: 1rem;
				margin-bottom: 0.35rem;
			}

			.esport-palmares li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.55em;
				width: 5px;
				height: 5px;
				border-radius: 1px;
				background: var(--color-rouge);
			}

			.esport-roster li {
				margin-bottom: 0.28rem;
			}

			.esport-roster-muted,
			.esport-staff-muted {
				opacity: 0.92;
			}

			.esport-real {
				font-weight: 500;
				color: var(--color-noir-2);
			}

			.esport-note {
				font-size: 0.82rem;
				color: var(--color-gris);
			}

			.esport-staff {
				margin-top: 0.35rem;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}

			.esport-staff li {
				margin-bottom: 0.2rem;
			}

			.esport-staff-role {
				color: var(--color-noir);
				font-weight: 700;
			}

			.esport-footnote {
				margin-top: 0.85rem;
				font-size: 0.82rem;
				line-height: 1.5;
				color: var(--color-gris);
				flex-grow: 1;
			}

			.esport-liquipedia {
				margin-top: 1rem;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--color-rouge);
				text-decoration: none;
				align-self: flex-start;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s ease, color 0.2s ease;
			}

			.esport-liquipedia:hover {
				border-bottom-color: var(--color-rouge);
				color: var(--color-noir);
			}

		</style>
	</body>
</html>
