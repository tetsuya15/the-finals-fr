---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { NAV_SECTIONS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import catRanked from '../assets/cat-ranked.jpg';
import catMeta from '../assets/cat-meta.jpg';
import catEsport from '../assets/cat-esport.jpg';
import catWiki from '../assets/cat-wiki.jpg';
import catActus from '../assets/cat-actus.jpg';
import catLore from '../assets/cat-lore.jpg';

const CAT_IMG = {
	ranked: catRanked,
	meta: catMeta,
	esport: catEsport,
	wiki: catWiki,
	actus: catActus,
	lore: catLore,
};

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = allPosts[0];
const latest = allPosts.slice(1, 5);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`${SITE_TITLE} — Ranked, Meta & Esport`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ============ HERO ============ -->
			<section class="hero">
				<canvas id="hero-canvas" aria-hidden="true"></canvas>
				<div class="hero-bg" aria-hidden="true"></div>
				<div class="scanlines" aria-hidden="true"></div>

				<div class="hero-content">
					<div class="broadcast">
						<span class="dot blink">●</span>
						<span>En direct</span>
						<span class="sep">·</span>
						<span>Saison 10 · Fantasy League</span>
						<span class="sep">·</span>
						<span>Site communautaire FR</span>
					</div>

					<h1 class="hero-title">
						<span class="line1">Bienvenue dans</span>
						<span class="line2">L'Arène</span>
					</h1>

					<p class="hero-sub">
						Le site communautaire francophone <strong>100% dédié au compétitif</strong> sur
						<strong>THE FINALS</strong>. Guides ranked, tier lists meta, couverture esport du
						Grand Major, et un wiki en français.
					</p>

					<div class="hero-cta">
						<a class="btn btn-primary" href="/ranked/">Voir les guides Ranked</a>
						<a class="btn btn-outline" href="/blog/">Tous les articles</a>
					</div>

					<div class="hero-meta">
						<div class="stat-box">
							<span class="number">S10</span>
							<span class="label">Saison couverte</span>
						</div>
						<div class="stat-box">
							<span class="number">6</span>
							<span class="label">Verticales édito</span>
						</div>
						<div class="stat-box">
							<span class="number">FR</span>
							<span class="label">100% francophone</span>
						</div>
						<div class="stat-box">
							<span class="number">0€</span>
							<span class="label">Free & open-source</span>
						</div>
					</div>
				</div>

				<div class="hero-scroll" aria-hidden="true">
					<span>Défiler</span>
					<div class="scroll-line"></div>
				</div>
			</section>

			<!-- ============ POSITIONNEMENT ============ -->
			<section class="intro">
				<div class="container">
					<div class="intro-grid">
						<div>
							<div class="section-label">À propos du site</div>
							<h2 class="section-title">Un seul jeu. <em>Un seul angle.</em> À fond.</h2>
							<p class="p">
								<strong>The Finals FR</strong> est le site communautaire francophone dédié au
								<strong>compétitif</strong> sur THE FINALS. Pas de dilution généraliste, pas de
								"10 jeux à la fois". On couvre <strong>un seul jeu</strong>, à fond, en français.
							</p>
							<p class="p">
								Articles produits via un <strong>workflow IA</strong> (draft automatique +
								recherche web + mise en forme), puis <strong>validés à la main</strong> avant
								publication. Rien ne part en ligne sans relecture humaine.
							</p>
							<div class="intro-tags">
								<span class="tag tag-red">Ranked</span>
								<span class="tag tag-gold">Meta</span>
								<span class="tag tag-blue">Esport</span>
								<span class="tag tag-white">Wiki</span>
								<span class="tag tag-green">Actus</span>
								<span class="tag tag-purple">Lore</span>
								<span class="tag tag-gold">FR</span>
								<span class="tag tag-red">Build in public</span>
							</div>
						</div>

						<div class="visual">
							<div class="visual-inner">
								<div class="v-eyebrow">The Finals FR · Manifeste</div>
								<p class="v-big">
									"On ne <em>couvre</em> pas dix jeux.<br />
									On fait <em class="gold">un</em> jeu, à fond, en <em class="gold">FR</em>."
								</p>
								<div class="v-tags">
									<span class="tag tag-red">Spécialiste</span>
									<span class="tag tag-gold">Compétitif</span>
									<span class="tag tag-white">Francophone</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- ============ SECTIONS / CATÉGORIES ============ -->
			<section class="sections">
				<div class="container">
					<div class="section-label">Catégories</div>
					<h2 class="section-title">Explore <em>le site</em></h2>
					<p class="section-desc">
						Six verticales éditoriales, chacune focalisée. Clique sur une catégorie pour
						lister tous ses articles.
					</p>

					<div class="sections-grid">
						{NAV_SECTIONS.map((s, i) => (
							<a class="sec-card card fade-up" href={`/${s.slug}/`} data-cat={s.label} style={`transition-delay:${i * 0.05}s`}>
								<div class="sec-img">
									<Image
										src={CAT_IMG[s.slug as keyof typeof CAT_IMG]}
										alt=""
										width={720}
										height={360}
										loading={i < 3 ? 'eager' : 'lazy'}
									/>
									<div class="sec-img-overlay"></div>
								</div>
								<div class="sec-body">
									<div class="sec-top">
										<span class="sec-num">0{i + 1}</span>
										<span class="tag tag-cat" data-cat={s.label}>{s.label}</span>
									</div>
									<h3 class="sec-title">{s.label}</h3>
									<p class="sec-desc">{s.description}</p>
									<span class="sec-arrow" aria-hidden="true">→</span>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- ============ LATEST / DIRECT ============ -->
			<section class="latest">
				<div class="container">
					<div class="section-label">Le direct</div>
					<h2 class="section-title">Derniers <em>articles</em></h2>

					{featured ? (
						<div class="news-grid">
							<a class="feat card fade-up" href={`/blog/${featured.id}/`}>
								{featured.data.heroImage && (
									<div class="feat-img">
										<Image
											src={featured.data.heroImage}
											alt=""
											width={960}
											height={540}
											loading="eager"
										/>
										<div class="feat-img-overlay"></div>
									</div>
								)}
								<div class="feat-body">
									<div class="feat-tags">
										{featured.data.category && (
											<span class="tag tag-cat" data-cat={featured.data.category}>
												{featured.data.category}
											</span>
										)}
										<span class="tag tag-gold">À la une</span>
									</div>
									<h3 class="feat-title">{featured.data.title}</h3>
									<p class="feat-desc">{featured.data.description}</p>
									<div class="feat-meta">
										<FormattedDate date={featured.data.pubDate} />
										{featured.data.author && <span>· par {featured.data.author}</span>}
									</div>
								</div>
							</a>

							<div class="news-sidebar">
								<div class="sb-header">Prochainement</div>
								{latest.length === 0 ? (
									<ul class="news-list">
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Ranked">Ranked</span>
											<h4>Guide Medium — comment grimper en S10</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Meta">Meta</span>
											<h4>Tier list armes S10 — tous les changements</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Esport">Esport</span>
											<h4>The Grand Major — qui est favori ?</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Wiki">Wiki</span>
											<h4>Les 3 classes en détail — Light, Medium, Heavy</h4>
											<span class="mini-date">À venir</span>
										</li>
									</ul>
								) : (
									<ul class="news-list">
										{latest.map((post) => (
											<li>
												<a class="card mini" href={`/blog/${post.id}/`}>
													{post.data.category && (
														<span class="tag tag-cat" data-cat={post.data.category}>
															{post.data.category}
														</span>
													)}
													<h4>{post.data.title}</h4>
													<span class="mini-date">
														<FormattedDate date={post.data.pubDate} />
													</span>
												</a>
											</li>
										))}
									</ul>
								)}
							</div>
						</div>
					) : (
						<div class="empty-full card">
							<p>
								<strong>Les premiers articles arrivent dans les jours qui viennent.</strong>
								<br />Premier guide Ranked, tier list S10 et couverture du Grand Major en préparation.
							</p>
						</div>
					)}
				</div>
			</section>

			<div class="divider"></div>

			<!-- ============ POURQUOI ============ -->
			<section class="reasons">
				<div class="container">
					<div class="section-label">Pourquoi ce site</div>
					<h2 class="section-title">Ce qu'on <em>fait différemment</em></h2>

					<div class="reasons-grid">
						<div class="card r-card fade-up">
							<div class="r-num">01</div>
							<div class="r-body">
								<h3>Compétitif uniquement</h3>
								<p>
									Pas de guide "comment installer le jeu". Ici c'est ranked, meta, esport.
									L'angle est verrouillé. Si tu veux grimper, t'es au bon endroit.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">02</div>
							<div class="r-body">
								<h3>100% français</h3>
								<p>
									Le seul site FR focus compétitif. Les sites généralistes FR traitent The
									Finals au milieu de 50 autres jeux. Nous, c'est uniquement ce jeu-là.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">03</div>
							<div class="r-body">
								<h3>Workflow IA transparent</h3>
								<p>
									Articles produits par IA, validés à la main. Code open-source sur GitHub.
									Le process est public — parce que c'est aussi ça le produit.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">04</div>
							<div class="r-body">
								<h3>Rythme soutenu</h3>
								<p>
									Le workflow IA permet de publier plusieurs articles par semaine sans
									sacrifier la qualité. Tier list à chaque patch, couverture chaque tournoi.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			// Hero particles canvas
			const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
			if (canvas) {
				const ctx = canvas.getContext('2d')!;
				let W = 0, H = 0;
				type Particle = {
					x: number; y: number; vx: number; vy: number;
					alpha: number; size: number; color: string;
				};
				let particles: Particle[] = [];

				function resize() {
					W = canvas!.width = canvas!.offsetWidth;
					H = canvas!.height = canvas!.offsetHeight;
				}

				function reset(p: Particle) {
					p.x = Math.random() * W;
					p.y = Math.random() * H + H * 0.2;
					p.vx = (Math.random() - 0.5) * 0.3;
					p.vy = -(Math.random() * 0.5 + 0.15);
					p.alpha = Math.random() * 0.6 + 0.1;
					p.size = Math.random() * 2.2 + 0.4;
					p.color = Math.random() > 0.72 ? '#F4A811' : '#C8102E';
				}

				function make(): Particle {
					const p = { x: 0, y: 0, vx: 0, vy: 0, alpha: 0, size: 0, color: '' };
					reset(p);
					return p;
				}

				resize();
				particles = Array.from({ length: 90 }, () => make());
				window.addEventListener('resize', resize);

				function loop() {
					ctx.clearRect(0, 0, W, H);
					for (const p of particles) {
						p.x += p.vx; p.y += p.vy; p.alpha -= 0.003;
						if (p.alpha <= 0 || p.y < -10) reset(p);
						ctx.save();
						ctx.globalAlpha = p.alpha;
						ctx.fillStyle = p.color;
						ctx.beginPath();
						ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
						ctx.fill();
						ctx.restore();
					}
					requestAnimationFrame(loop);
				}
				loop();
			}

			// Fade-up observer
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						e.target.classList.add('visible');
						observer.unobserve(e.target);
					}
				});
			}, { threshold: 0.12 });
			document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
		</script>

		<style>
			main { padding-bottom: 2rem; }

			/* ============ HERO ============ */
			.hero {
				position: relative;
				min-height: 92vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				overflow: hidden;
				padding: 5rem 1.5rem;
			}

			#hero-canvas {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.hero-bg {
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 80% 60% at 50% 60%, rgba(200,16,46,0.14) 0%, transparent 70%),
					radial-gradient(ellipse 40% 30% at 20% 80%, rgba(244,168,17,0.08) 0%, transparent 50%),
					radial-gradient(ellipse 40% 30% at 80% 20%, rgba(244,168,17,0.05) 0%, transparent 60%),
					linear-gradient(180deg, #080808 0%, #0f0505 50%, #080808 100%);
				z-index: 1;
			}

			.scanlines {
				position: absolute;
				inset: 0;
				background: repeating-linear-gradient(
					0deg,
					transparent 0,
					transparent 2px,
					rgba(0, 0, 0, 0.08) 2px,
					rgba(0, 0, 0, 0.08) 4px
				);
				z-index: 2;
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				z-index: 3;
				max-width: 960px;
				width: 100%;
			}

			.broadcast {
				display: inline-flex;
				align-items: center;
				gap: 0.7rem;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				color: var(--color-rouge);
				letter-spacing: 0.22em;
				text-transform: uppercase;
				margin-bottom: 1.3rem;
				flex-wrap: wrap;
				justify-content: center;
				padding: 0 0.5rem;
			}

			.broadcast::before,
			.broadcast::after {
				content: '';
				height: 1px;
				width: 48px;
				background: var(--color-rouge);
				opacity: 0.55;
			}

			.broadcast .dot {
				color: var(--color-rouge-2);
				font-size: 0.55rem;
			}

			.broadcast .sep {
				color: var(--color-gris);
				opacity: 0.6;
			}

			.hero-title {
				font-family: var(--font-display);
				font-size: clamp(3.5rem, 11vw, 9rem);
				font-weight: 900;
				line-height: 0.88;
				text-transform: uppercase;
				letter-spacing: -0.02em;
				margin-bottom: 0.5rem;
				animation: heroIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			@keyframes heroIn {
				from { opacity: 0; transform: translateY(40px) skewY(1.5deg); }
				to { opacity: 1; transform: translateY(0) skewY(0); }
			}

			.hero-title .line1 {
				display: block;
				color: var(--color-blanc);
			}

			.hero-title .line2 {
				display: block;
				color: var(--color-rouge);
				text-shadow:
					0 0 60px rgba(200, 16, 46, 0.8),
					0 0 120px rgba(200, 16, 46, 0.3);
			}

			.hero-sub {
				font-family: var(--font-sans);
				font-size: 1.05rem;
				font-weight: 400;
				color: rgba(240, 234, 214, 0.7);
				max-width: 600px;
				margin: 1.5rem auto 2.3rem;
				line-height: 1.65;
				animation: heroIn 0.9s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			.hero-sub strong {
				color: var(--color-blanc);
				font-weight: 600;
			}

			.hero-cta {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
				animation: heroIn 0.9s 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			.hero-meta {
				margin-top: 3.5rem;
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 0.75rem;
				max-width: 720px;
				margin-left: auto;
				margin-right: auto;
				animation: heroIn 0.9s 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			@media (min-width: 768px) {
				.hero-meta { grid-template-columns: repeat(4, 1fr); }
			}

			.hero-scroll {
				position: absolute;
				bottom: 1.5rem;
				left: 50%;
				transform: translateX(-50%);
				z-index: 3;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.4rem;
				opacity: 0.55;
				animation: float 2s ease-in-out infinite;
			}

			@keyframes float {
				0%, 100% { transform: translateX(-50%) translateY(0); }
				50%      { transform: translateX(-50%) translateY(6px); }
			}

			.hero-scroll span {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				letter-spacing: 0.22em;
				color: var(--color-gris);
				text-transform: uppercase;
			}

			.scroll-line {
				width: 1px;
				height: 40px;
				background: linear-gradient(to bottom, var(--color-rouge), transparent);
			}

			/* ============ INTRO ============ */
			.intro {
				padding: 5rem 0 4rem;
				background: var(--color-gris-3);
				border-top: 1px solid rgba(200, 16, 46, 0.18);
				border-bottom: 1px solid rgba(200, 16, 46, 0.18);
			}

			.intro-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 3rem;
				align-items: center;
			}

			@media (min-width: 900px) {
				.intro-grid { grid-template-columns: 1.2fr 1fr; gap: 4rem; }
			}

			.p {
				color: rgba(240, 234, 214, 0.7);
				line-height: 1.75;
				margin-bottom: 1em;
			}

			.p strong { color: var(--color-blanc); font-weight: 600; }

			.intro-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}

			.visual {
				padding: 0;
			}

			.visual-inner {
				background: linear-gradient(135deg, rgba(200,16,46,0.1), rgba(244,168,17,0.05));
				border: 1px solid rgba(200, 16, 46, 0.2);
				border-radius: 3px;
				padding: 2.5rem 2rem;
				position: relative;
				overflow: hidden;
			}

			.visual-inner::before {
				content: 'THE FINALS';
				position: absolute;
				font-family: var(--font-display);
				font-size: 6rem;
				font-weight: 900;
				color: rgba(200, 16, 46, 0.05);
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				white-space: nowrap;
				letter-spacing: 0.1em;
				pointer-events: none;
			}

			.v-eyebrow {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: var(--color-rouge);
				margin-bottom: 1.25rem;
				position: relative;
			}

			.v-big {
				font-family: var(--font-display);
				font-size: clamp(1.4rem, 2.5vw, 2rem);
				font-weight: 800;
				text-transform: uppercase;
				line-height: 1.15;
				color: var(--color-blanc);
				position: relative;
				margin-bottom: 1.5rem;
			}

			.v-big em {
				font-style: normal;
				color: var(--color-rouge-2);
			}

			.v-big em.gold {
				color: var(--color-or);
			}

			.v-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				position: relative;
			}

			/* ============ SECTIONS GRID ============ */
			.sections {
				padding: 5rem 0 4rem;
			}

			.sections-grid {
				display: grid;
