---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import heroBg from '../assets/hero-bienvenue.png';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = allPosts[0];
const latest = allPosts.slice(1, 5);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`${SITE_TITLE} — Ranked, Meta & Esport`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ============ HERO ============ -->
			<section class="hero">
				<div class="hero-media" aria-hidden="true">
					<div class="hero-media-parallax" id="heroMedia">
						<div class="hero-media-zoom">
							<Image
								src={heroBg}
								alt=""
								width={1920}
								height={1080}
								densities={[1, 2]}
								quality={92}
								loading="eager"
								sizes="100vw"
							/>
						</div>
					</div>
					<div class="hero-glitch"></div>
					<div class="hero-scanline"></div>
					<div class="hero-wash"></div>
				</div>

				<div class="hero-content">
					<div class="broadcast-bar" aria-label="Bandeau d'informations The Finals FR">
						<span class="rec-badge" aria-hidden="true">
							<span class="rec-dot">
								<span class="rec-ring"></span>
								<span class="rec-ring"></span>
							</span>
							<span class="rec-text">REC</span>
						</span>
						<div class="marquee">
							<div class="marquee-track">
								<div class="marquee-group">
									<span>En direct</span>
									<span class="sep">·</span>
									<span>Saison 10 · Fantasy League</span>
									<span class="sep">·</span>
									<span>Site communautaire FR</span>
									<span class="sep">·</span>
									<span>Grand Major en couverture</span>
									<span class="sep">·</span>
									<span>Tier list meta mise à jour chaque patch</span>
									<span class="sep">·</span>
									<span>Guides ranked testés en jeu</span>
									<span class="sep">·</span>
								</div>
								<div class="marquee-group" aria-hidden="true">
									<span>En direct</span>
									<span class="sep">·</span>
									<span>Saison 10 · Fantasy League</span>
									<span class="sep">·</span>
									<span>Site communautaire FR</span>
									<span class="sep">·</span>
									<span>Grand Major en couverture</span>
									<span class="sep">·</span>
									<span>Tier list meta mise à jour chaque patch</span>
									<span class="sep">·</span>
									<span>Guides ranked testés en jeu</span>
									<span class="sep">·</span>
								</div>
							</div>
						</div>
					</div>

					<h1 class="hero-title">
						<span class="line1" data-split>Bienvenue dans</span>
						<span class="line2" data-split>L'Arène</span>
					</h1>

					<p class="hero-sub">
						Le site communautaire francophone <strong>100% dédié au compétitif</strong> sur
						<strong>THE FINALS</strong>. Guides ranked, tier lists meta, couverture esport
						du Grand Major, et un wiki en français.
					</p>

					<div class="hero-cta">
						<a class="btn btn-primary is-magnetic" href="/ranked/">Voir les guides Ranked</a>
						<a class="btn btn-outline" href="/blog/">Tous les articles</a>
					</div>

					<div class="hero-meta">
						<div class="stat-box stat-flip" style="--i:0">
							<span class="number">S10</span>
							<span class="label">Saison couverte</span>
						</div>
						<div class="stat-box stat-flip" style="--i:1">
							<span class="number">6</span>
							<span class="label">Verticales édito</span>
						</div>
						<div class="stat-box stat-flip" style="--i:2">
							<span class="number">FR</span>
							<span class="label">100% francophone</span>
						</div>
						<div class="stat-box stat-flip" style="--i:3">
							<span class="number">0€</span>
							<span class="label">Free & open-source</span>
						</div>
					</div>
				</div>

				<div class="hero-scroll" aria-hidden="true">
					<span>Défiler</span>
					<div class="scroll-line"></div>
				</div>
			</section>

			<div class="tfr-stripes" aria-hidden="true"></div>

			<!-- ============ À PROPOS DU JEU ============ -->
			<section class="intro">
				<div class="container">
					<div class="intro-grid">
						<div>
							<div class="section-label">À propos du jeu</div>
							<h2 class="section-title">Un <em>game show</em> où tout s'écroule.</h2>
							<p class="p">
								<strong>THE FINALS</strong> est un FPS free-to-play signé
								<strong>Embark Studios</strong> (studio suédois fondé par d'anciens
								de DICE), sorti en <strong>décembre 2023</strong>. Le pitch :
								un jeu télévisé futuriste où des équipes de concurrents s'affrontent
								devant un public virtuel pour voler, transporter et déposer des
								coffres-forts remplis de cash.
							</p>
							<p class="p">
								Le mode roi, c'est le <strong>Cashout</strong> — quatre équipes de
								trois sur la même carte, un seul objectif. Trois classes à choisir
								(<strong>Light</strong>, <strong>Medium</strong>,
								<strong>Heavy</strong>), chacune avec ses armes et ses gadgets. Et
								surtout : des <strong>arènes entièrement destructibles</strong>. Les
								murs tombent, les plafonds s'effondrent, chaque match est unique.
							</p>
							<p class="p">
								Entre le <strong>Ranked Tournament</strong>, les
								<strong>World Tour</strong> officiels, <strong>Terminal Attack</strong>
								et <strong>Power Shift</strong>, il y a de quoi jouer chill ou viser
								le top mondial. C'est ce jeu-là qu'on couvre ici, en français.
							</p>
							<div class="intro-tags">
								<span class="tag tag-red">Free-to-play</span>
								<span class="tag tag-dark">FPS compétitif</span>
								<span class="tag tag-dark">Embark Studios</span>
								<span class="tag tag-dark">PC · PS5 · Xbox</span>
								<span class="tag tag-white">Déc. 2023</span>
							</div>
						</div>

						<div class="visual">
							<div class="visual-inner">
								<div class="v-stripes" aria-hidden="true"></div>
								<div class="v-eyebrow">THE FINALS · Fiche express</div>
								<p class="v-big">
									"Des <em>coffres</em>.<br />
									Du <em>cash</em>.<br />
									Des <em>murs</em> qui tombent."
								</p>
								<div class="v-tags">
									<span class="tag tag-red">3 classes</span>
									<span class="tag tag-dark">5 modes</span>
									<span class="tag tag-white">100% destructible</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<div class="tfr-stripes -thin" aria-hidden="true"></div>

			<!-- ============ LATEST / DIRECT ============ -->
			<section class="latest">
				<div class="container">
					<div class="section-label">Le direct</div>
					<h2 class="section-title">Derniers <em>articles</em></h2>

					{featured ? (
						<div class="news-grid">
							<a class="feat card fade-up" href={`/blog/${featured.id}/`}>
								{featured.data.heroImage && (
									<div class="feat-img">
										<Image
											src={featured.data.heroImage}
											alt=""
											width={960}
											height={540}
											loading="eager"
										/>
									</div>
								)}
								<div class="feat-body">
									<div class="feat-tags">
										{featured.data.category && (
											<span class="tag tag-cat" data-cat={featured.data.category}>
												{featured.data.category}
											</span>
										)}
										<span class="tag tag-red">À la une</span>
									</div>
									<h3 class="feat-title">{featured.data.title}</h3>
									<p class="feat-desc">{featured.data.description}</p>
									<div class="feat-meta">
										<FormattedDate date={featured.data.pubDate} />
										{featured.data.author && <span>· par {featured.data.author}</span>}
									</div>
								</div>
							</a>

							<div class="news-sidebar">
								<div class="sb-header">Prochainement</div>
								{latest.length === 0 ? (
									<ul class="news-list">
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Ranked">Ranked</span>
											<h4>Guide Medium — comment grimper en S10</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Meta">Meta</span>
											<h4>Tier list armes S10 — tous les changements</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Esport">Esport</span>
											<h4>The Grand Major — qui est favori ?</h4>
											<span class="mini-date">À venir</span>
										</li>
										<li class="card mini">
											<span class="tag tag-cat" data-cat="Wiki">Wiki</span>
											<h4>Les 3 classes en détail — Light, Medium, Heavy</h4>
											<span class="mini-date">À venir</span>
										</li>
									</ul>
								) : (
									<ul class="news-list">
										{latest.map((post) => (
											<li>
												<a class="card mini" href={`/blog/${post.id}/`}>
													{post.data.category && (
														<span class="tag tag-cat" data-cat={post.data.category}>
															{post.data.category}
														</span>
													)}
													<h4>{post.data.title}</h4>
													<span class="mini-date">
														<FormattedDate date={post.data.pubDate} />
													</span>
												</a>
											</li>
										))}
									</ul>
								)}
							</div>
						</div>
					) : (
						<div class="empty-full card">
							<p>
								<strong>Les premiers articles arrivent dans les jours qui viennent.</strong>
								<br />Premier guide Ranked, tier list S10 et couverture du Grand Major en préparation.
							</p>
						</div>
					)}
				</div>
			</section>

			<!-- ============ POURQUOI ============ -->
			<section class="reasons">
				<div class="container">
					<div class="section-label">Pourquoi ce site</div>
					<h2 class="section-title">Ce qu'on <em>fait différemment</em></h2>

					<div class="reasons-grid">
						<div class="card r-card fade-up">
							<div class="r-num">01</div>
							<div class="r-body">
								<h3>Compétitif uniquement</h3>
								<p>
									Pas de guide "comment installer le jeu". Ici c'est ranked, meta,
									esport. L'angle est verrouillé. Si tu veux grimper, t'es au bon endroit.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">02</div>
							<div class="r-body">
								<h3>100% français</h3>
								<p>
									Le seul site FR focus compétitif. Les sites généralistes FR traitent
									The Finals au milieu de 50 autres jeux. Nous, c'est uniquement ce jeu-là.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">03</div>
							<div class="r-body">
								<h3>À jour à chaque patch</h3>
								<p>
									Tier list révisée à chaque mise à jour, guides ranked actualisés à
									chaque saison, couverture esport suivie tournoi par tournoi. Pas
									d'article qui traîne six mois après un rework.
								</p>
							</div>
						</div>

						<div class="card r-card fade-up">
							<div class="r-num">04</div>
							<div class="r-body">
								<h3>Rythme soutenu</h3>
								<p>
									Plusieurs articles par semaine sans sacrifier la qualité. Tier list
									à chaque patch, couverture chaque tournoi, guides approfondis.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const canHover = window.matchMedia('(hover: hover)').matches;

			// Reveal on scroll (wipe + fade)
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						e.target.classList.add('visible');
						observer.unobserve(e.target);
					}
				});
			}, { threshold: 0.12 });
			document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));

			// Split-letter cascade on hero title
			if (!reduced) {
				document.querySelectorAll('[data-split]').forEach((el) => {
					const node = /** @type {HTMLElement} */ (el);
					const text = node.textContent || '';
					node.classList.add('split-line');
					node.setAttribute('aria-label', text);
					node.textContent = '';
					let i = 0;
					for (const ch of text) {
						const span = document.createElement('span');
						span.className = 'split-char' + (ch === ' ' ? ' space' : '');
						span.style.setProperty('--i', String(i++));
						span.setAttribute('aria-hidden', 'true');
						span.textContent = ch === ' ' ? '\u00A0' : ch;
						node.appendChild(span);
					}
				});
			}

			// Section titles — split by word, reveal line-by-line on scroll
			if (!reduced) {
				document.querySelectorAll('.section-title').forEach((el) => {
					const node = /** @type {HTMLElement} */ (el);
					const html = node.innerHTML;
					// Wrap each word (preserving inline tags like <em>)
					const tmp = document.createElement('div');
					tmp.innerHTML = html;
					let wordIdx = 0;
					const wrapTextNode = (textNode) => {
						const words = (textNode.nodeValue || '').split(/(\s+)/);
						const frag = document.createDocumentFragment();
						words.forEach((w) => {
							if (!w) return;
							if (/^\s+$/.test(w)) {
								frag.appendChild(document.createTextNode(w));
							} else {
								const word = document.createElement('span');
								word.className = 'word';
								const inner = document.createElement('span');
								inner.style.setProperty('--i', String(wordIdx++));
								inner.textContent = w;
								word.appendChild(inner);
								frag.appendChild(word);
							}
						});
						return frag;
					};
					const walk = (parent) => {
						const children = Array.from(parent.childNodes);
						children.forEach((child) => {
							if (child.nodeType === 3) {
								parent.replaceChild(wrapTextNode(child), child);
							} else if (child.nodeType === 1) {
								walk(child);
							}
						});
					};
					walk(tmp);
					node.innerHTML = tmp.innerHTML;
				});

				const titleObserver = new IntersectionObserver((entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							e.target.classList.add('is-visible');
							titleObserver.unobserve(e.target);
						}
					});
				}, { threshold: 0.3 });
				document.querySelectorAll('.section-title').forEach((el) => titleObserver.observe(el));
			}

			// Parallax on hero background (outer wrapper; Ken Burns animates the inner)
			if (!reduced) {
				const media = document.getElementById('heroMedia');
				if (media) {
					let raf = 0;
					const apply = () => {
						const y = Math.min(window.scrollY, 800);
						media.style.transform = `translate3d(0, ${(y * 0.25).toFixed(2)}px, 0)`;
						raf = 0;
					};
					const onScroll = () => {
						if (raf) return;
						raf = requestAnimationFrame(apply);
					};
					window.addEventListener('scroll', onScroll, { passive: true });
					apply();
				}
			}

			// Magnetic primary buttons
			if (!reduced && canHover) {
				document.querySelectorAll('.btn.is-magnetic').forEach((btn) => {
					const el = /** @type {HTMLElement} */ (btn);
					const strength = 14;
					el.addEventListener('mousemove', (e) => {
						const r = el.getBoundingClientRect();
						const mx = ((e.clientX - r.left) / r.width - 0.5) * strength;
						const my = ((e.clientY - r.top) / r.height - 0.5) * strength;
						el.style.setProperty('--mx', mx.toFixed(2) + 'px');
						el.style.setProperty('--my', my.toFixed(2) + 'px');
					});
					el.addEventListener('mouseleave', () => {
						el.style.setProperty('--mx', '0px');
						el.style.setProperty('--my', '0px');
					});
				});
			}

			// 3D tilt on cards with [data-tilt]
			if (!reduced && canHover) {
				const MAX = 7; // degrees
				document.querySelectorAll('[data-tilt]').forEach((el) => {
					const node = /** @type {HTMLElement} */ (el);
					let raf = 0;
					let rx = 0, ry = 0;
					const apply = () => {
						node.style.transform = `perspective(1000px) rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg) translateZ(0)`;
						raf = 0;
					};
					node.addEventListener('mousemove', (e) => {
						const r = node.getBoundingClientRect();
						const px = (e.clientX - r.left) / r.width;
						const py = (e.clientY - r.top) / r.height;
						ry = (px - 0.5) * MAX * 2;
						rx = -(py - 0.5) * MAX * 2;
						if (!raf) raf = requestAnimationFrame(apply);
					});
					node.addEventListener('mouseenter', () => node.classList.add('is-tilting'));
					node.addEventListener('mouseleave', () => {
						node.classList.remove('is-tilting');
						rx = 0; ry = 0;
						apply();
					});
				});
			}
		</script>

		<style>
			main { padding-bottom: 0; }

			/* ============ HERO ============ */
			.hero {
				position: relative;
				min-height: 88vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				overflow: hidden;
				padding: 5rem 1.5rem 6rem;
				background: var(--color-cream);
			}

			.hero-media {
				position: absolute;
				inset: 0;
				z-index: 0;
				background: var(--color-cream);
			}

			.hero-media-parallax {
				position: absolute;
				inset: 0;
				z-index: 0;
				overflow: hidden;
				will-change: transform;
			}

			.hero-media-zoom :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				opacity: 0.32;
			}

			/* Very soft tint — image is already at 18% opacity on its own */
			.hero-wash {
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 60% 45% at 50% 35%, rgba(228, 0, 43, 0.06) 0%, transparent 70%),
					linear-gradient(180deg, transparent 55%, rgba(245, 241, 232, 0.6) 100%);
			}

			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 960px;
				width: 100%;
			}

			.broadcast-bar {
				margin: 0 auto 1.7rem;
			}

			.marquee {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				color: var(--color-rouge);
				letter-spacing: 0.22em;
				text-transform: uppercase;
				text-shadow: 0 1px 2px rgba(245, 241, 232, 0.85);
			}

			.marquee .sep {
				color: var(--color-gris);
				opacity: 0.55;
			}

			.hero-title {
				font-family: var(--font-display);
				font-size: clamp(3.5rem, 11vw, 9rem);
				font-weight: 900;
				line-height: 0.9;
				text-transform: uppercase;
				letter-spacing: -0.02em;
				margin-bottom: 0.5rem;
				animation: heroIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			@keyframes heroIn {
				from { opacity: 0; transform: translateY(32px); }
				to { opacity: 1; transform: translateY(0); }
			}

			.hero-title .line1 {
				display: block;
				color: var(--color-noir);
				text-shadow: 0 2px 24px rgba(255, 255, 255, 0.5);
			}

			.hero-title .line2 {
				display: block;
				color: var(--color-rouge);
				text-shadow: 0 2px 30px rgba(255, 255, 255, 0.6);
			}

			.hero-sub {
				font-family: var(--font-sans);
				font-size: 1.1rem;
				font-weight: 500;
				color: var(--color-noir);
				max-width: 640px;
				margin: 1.5rem auto 2.3rem;
				line-height: 1.65;
				animation: heroIn 0.9s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
				text-shadow: 0 1px 2px rgba(245, 241, 232, 0.8);
			}

			.hero-sub strong { color: var(--color-rouge); font-weight: 700; }

			.hero-cta {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
				animation: heroIn 0.9s 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			.hero-meta {
				margin-top: 3rem;
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 0.75rem;
				max-width: 720px;
				margin-left: auto;
				margin-right: auto;
				animation: heroIn 0.9s 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
			}

			@media (min-width: 768px) {
				.hero-meta { grid-template-columns: repeat(4, 1fr); }
			}

			.hero-scroll {
				position: absolute;
				bottom: 1.5rem;
				left: 50%;
				transform: translateX(-50%);
				z-index: 3;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.4rem;
				animation: float 2s ease-in-out infinite;
			}

			@keyframes float {
				0%, 100% { transform: translateX(-50%) translateY(0); }
				50%      { transform: translateX(-50%) translateY(6px); }
			}

			.hero-scroll span {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				letter-spacing: 0.22em;
				color: var(--color-noir);
				text-transform: uppercase;
			}

			.scroll-line {
				width: 1px;
				height: 40px;
				background: linear-gradient(to bottom, var(--color-rouge), transparent);
			}

			/* ============ INTRO ============ */
			.intro {
				padding: 5rem 0 4rem;
				background: var(--color-blanc);
				border-bottom: 1px solid var(--color-border);
			}

			.intro-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 3rem;
				align-items: center;
			}

			@media (min-width: 900px) {
				.intro-grid { grid-template-columns: 1.2fr 1fr; gap: 4rem; }
			}

			.p {
				color: var(--color-noir-2);
				line-height: 1.75;
				margin-bottom: 1em;
				font-size: 1rem;
			}

			.p strong { color: var(--color-rouge); font-weight: 600; }

			.intro-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}

			.visual-inner {
				background: var(--color-cream-2);
				border: 1px solid var(--color-border);
				border-radius: 3px;
				padding: 2.5rem 2rem;
				position: relative;
				overflow: hidden;
			}

			.v-stripes {
				position: absolute;
				top: 0;
				right: 0;
				width: 4px;
				height: 100%;
				background: var(--color-rouge);
			}

			.v-eyebrow {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: var(--color-rouge);
				margin-bottom: 1.25rem;
				position: relative;
			}

			.v-big {
				font-family: var(--font-display);
				font-size: clamp(1.3rem, 2.2vw, 1.8rem);
				font-weight: 800;
				text-transform: uppercase;
				line-height: 1.2;
				color: var(--color-noir);
				position: relative;
				margin-bottom: 1.5rem;
			}

			.v-big em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.v-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				position: relative;
			}

			/* ============ LATEST / DIRECT ============ */
			.latest {
				padding: 5rem 0 4rem;
				background: var(--color-blanc);
			}

			.news-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
				margin-top: 1rem;
			}

			@media (min-width: 900px) {
				.news-grid { grid-template-columns: 2fr 1fr; gap: 2rem; }
			}

			.feat {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				overflow: hidden;
			}

			.feat-img {
				position: relative;
				aspect-ratio: 16 / 9;
				overflow: hidden;
			}

			.feat-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.feat:hover .feat-img :global(img) { transform: scale(1.04); }

			.feat-body {
				padding: 1.75rem;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				background: var(--color-blanc);
			}

			.feat-tags {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 1rem;
				flex-wrap: wrap;
			}

			.feat-title {
				font-family: var(--font-display);
				font-size: clamp(1.4rem, 2.5vw, 2rem);
				font-weight: 900;
				text-transform: uppercase;
				letter-spacing: -0.005em;
				line-height: 1.1;
				color: var(--color-noir);
				margin-bottom: 0.8rem;
				transition: color 0.2s ease;
			}

			.feat:hover .feat-title { color: var(--color-rouge); }

			.feat-desc {
				color: var(--color-noir-2);
				font-size: 0.95rem;
				line-height: 1.6;
				margin-bottom: 1.25rem;
				flex-grow: 1;
			}

			.feat-meta {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-gris);
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}

			.news-sidebar {
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
			}

			.sb-header {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--color-rouge);
				padding-bottom: 0.5rem;
				border-bottom: 1px solid rgba(228, 0, 43, 0.25);
			}

			.news-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
			}

			.mini {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				padding: 1.1rem 1.2rem;
				text-decoration: none;
				border-left: 3px solid var(--color-rouge);
				background: var(--color-cream-2);
			}

			.mini h4 {
				font-family: var(--font-display);
				font-size: 1rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				line-height: 1.2;
				color: var(--color-noir);
			}

			.mini:hover h4 { color: var(--color-rouge); }

			.mini-date {
				font-family: var(--font-mono);
				font-size: 0.62rem;
				color: var(--color-gris);
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.empty-full {
				padding: 2.5rem;
				text-align: center;
				color: var(--color-noir-2);
				font-size: 0.95rem;
				line-height: 1.7;
				background: var(--color-cream-2);
			}

			.empty-full strong { color: var(--color-rouge); }

			/* ============ REASONS ============ */
			.reasons {
				padding: 5rem 0;
			}

			.reasons-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.2rem;
				margin-top: 1rem;
			}

			@media (min-width: 768px) {
				.reasons-grid { grid-template-columns: repeat(2, 1fr); }
			}

			.r-card {
				padding: 2rem;
				display: flex;
				gap: 1.5rem;
				align-items: flex-start;
				background: var(--color-blanc);
			}

			.r-num {
				font-family: var(--font-display);
				font-size: 3rem;
				font-weight: 900;
				color: var(--color-rouge);
				opacity: 0.2;
				line-height: 1;
				flex-shrink: 0;
			}

			.r-body h3 {
				font-family: var(--font-display);
				font-size: 1.2rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				margin-bottom: 0.5rem;
				color: var(--color-noir);
			}

			.r-body p {
				font-size: 0.92rem;
				color: var(--color-gris);
				line-height: 1.65;
			}
		</style>
	</body>
</html>
