---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos — ${SITE_TITLE}`}
			description={`À propos de ${SITE_TITLE}, le site francophone dédié au compétitif sur The Finals.`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="container">
					<div class="section-label">{SITE_TITLE} — À propos</div>
					<h1 class="title">
						Un seul jeu.<br />
						Un seul angle. <em>À fond.</em>
					</h1>
					<p class="lead">
						<strong>{SITE_TITLE}</strong> est le site communautaire francophone dédié au
						<em>compétitif</em> sur The Finals : ranked, communauté, esport, et tout ce qu'il faut
						pour grimper et comprendre le jeu en profondeur.
					</p>
				</div>
			</section>

			<div class="tfr-stripes" aria-hidden="true"></div>

			<section class="block">
				<div class="container">
					<div class="block-grid">
						<div>
							<div class="section-label">01 — Pourquoi</div>
							<h2 class="h">Parce que personne ne le fait, <em>en français.</em></h2>
						</div>
						<div class="block-body">
							<p>
								The Finals a une scène compétitive qui explose — <strong>Grand Major</strong>,
								équipes pro, circuit mondial — et pourtant, en français, personne ne la couvre
								sérieusement. Les sites FR existants traitent le jeu à la volée, au milieu de
								cinquante autres titres. Ici, on fait <strong>une chose</strong>, à fond.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="block -alt">
				<div class="container">
					<div class="block-grid">
						<div>
							<div class="section-label">02 — Ce qu'on publie</div>
							<h2 class="h">Cinq verticales, <em>zéro dilution.</em></h2>
						</div>
						<ul class="verticals">
							<li class="card v-item"><span class="tag tag-cat" data-cat="Ranked">Ranked</span> Guides pour grimper — par classe, par mode, par saison.</li>
							<li class="card v-item"><span class="tag tag-cat" data-cat="Meta">Communauté</span> Tier lists armes, builds OP, lecture des patchs.</li>
							<li class="card v-item"><span class="tag tag-cat" data-cat="Esport">Esport</span> Grand Major, équipes pro, analyses de matchs.</li>
							<li class="card v-item"><span class="tag tag-cat" data-cat="Wiki">Wiki</span> Fiches classes, armes, spécialisations, gadgets, cartes.</li>
							<li class="card v-item"><span class="tag tag-cat" data-cat="Actus">Actus</span> Patch notes décryptés, saisons, events communautaires.</li>
						</ul>
					</div>
				</div>
			</section>

		</main>
		<Footer />

		<style>
			main { padding-bottom: 2rem; }

			.hero {
				padding: 5rem 0 3.5rem;
				background: var(--color-blanc);
			}

			.title {
				font-size: clamp(2.5rem, 7vw, 5.5rem);
				text-transform: uppercase;
				letter-spacing: -0.025em;
				line-height: 0.98;
				margin-top: 1rem;
				color: var(--color-noir);
			}

			.title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.lead {
				margin-top: 1.5rem;
				max-width: 60ch;
				font-size: 1.15rem;
				color: var(--color-noir-2);
				line-height: 1.65;
			}

			.lead strong { color: var(--color-rouge); }
			.lead em { font-style: normal; color: var(--color-noir); font-weight: 500; }

			.block {
				padding: 4rem 0;
			}

			.block.-alt {
				background: var(--color-cream-2);
				border-top: 1px solid var(--color-border);
				border-bottom: 1px solid var(--color-border);
			}

			.block-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 2rem;
			}

			@media (min-width: 900px) {
				.block-grid {
					grid-template-columns: 1fr 1.3fr;
					gap: 4rem;
					align-items: start;
				}
			}

			.h {
				font-size: clamp(1.75rem, 3.5vw, 2.6rem);
				text-transform: uppercase;
				letter-spacing: -0.01em;
				line-height: 1.05;
				margin-top: 0.8rem;
				color: var(--color-noir);
			}

			.h em { font-style: normal; color: var(--color-rouge); }

			.block-body p {
				color: var(--color-noir-2);
				font-size: 1rem;
				line-height: 1.75;
			}

			.block-body p + p { margin-top: 1em; }

			.block-body p strong { color: var(--color-rouge); }

			.verticals {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
			}

			.v-item {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.8rem;
				padding: 1rem 1.25rem;
				color: var(--color-noir-2);
				font-size: 0.95rem;
				line-height: 1.5;
				background: var(--color-blanc);
			}

		</style>
	</body>
</html>
