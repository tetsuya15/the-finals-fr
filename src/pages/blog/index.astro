---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Tous les articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-hero">
				<div class="tfr-container">
					<span class="tfr-eyebrow">{SITE_TITLE} <span class="tfr-pipe">|</span> Archive</span>
					<h1 class="blog-title">Tous les articles</h1>
					<p class="blog-desc">
						Guides ranked, analyses meta, couverture esport, patchs — le flux complet.
					</p>
				</div>
			</section>

			<section class="blog-list">
				<div class="tfr-container">
					{posts.length === 0 ? (
						<div class="empty">
							<p>
								<strong>Les premiers articles arrivent dans les jours qui viennent.</strong><br />
								On construit le site en public — reviens vite.
							</p>
						</div>
					) : (
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a class="post-row" href={`/blog/${post.id}/`}>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<div class="post-body">
											{post.data.category && (
												<span class="tfr-badge" data-cat={post.data.category}>
													{post.data.category}
												</span>
											)}
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
										</div>
										<span class="post-arrow" aria-hidden="true">→</span>
									</a>
								</li>
							))}
						</ul>
					)}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding-bottom: 2rem;
	}

	.blog-hero {
		padding: 5rem 0 3rem;
		border-bottom: 1px solid var(--color-border);
	}

	.blog-title {
		font-size: clamp(3rem, 9vw, 6rem);
		text-transform: uppercase;
		letter-spacing: -0.03em;
		line-height: 0.95;
		margin-top: 1.25rem;
	}

	.blog-desc {
		margin-top: 1.25rem;
		max-width: 60ch;
		color: var(--color-text-muted);
		font-size: 1.1rem;
		line-height: 1.65;
	}

	.blog-list {
		padding: 4rem 0;
	}

	.empty {
		padding: 3rem;
		border: 1px dashed var(--color-border);
		text-align: center;
		color: var(--color-text-muted);
	}

	.empty strong {
		color: var(--color-text);
	}

	.posts {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.posts li {
		border-top: 1px solid var(--color-border);
	}

	.posts li:last-child {
		border-bottom: 1px solid var(--color-border);
	}

	.post-row {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1rem;
		padding: 2rem 0;
		transition: padding 0.2s ease;
	}

	@media (min-width: 768px) {
		.post-row {
			grid-template-columns: 160px 1fr auto;
			gap: 2.5rem;
			align-items: start;
		}
	}

	.post-row:hover {
		padding-left: 1rem;
	}

	.post-date {
		font-family: var(--font-display);
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-dim);
	}

	.post-body h3 {
		font-size: clamp(1.3rem, 2vw, 1.75rem);
		text-transform: uppercase;
		line-height: 1.15;
		margin: 0.75rem 0 0.5rem;
		transition: color 0.2s ease;
	}

	.post-row:hover .post-body h3 {
		color: var(--color-accent);
	}

	.post-body p {
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.post-arrow {
		font-family: var(--font-display);
		font-size: 1.4rem;
		color: var(--color-text-dim);
		transition: color 0.2s ease, transform 0.2s ease;
		align-self: center;
	}

	.post-row:hover .post-arrow {
		color: var(--color-accent);
		transform: translateX(6px);
	}
</style>
