---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Tous les articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-hero">
				<div class="container">
					<div class="section-label">{SITE_TITLE} — Archive</div>
					<h1 class="blog-title">Tous les <em>articles</em></h1>
					<p class="blog-desc">
						Guides ranked, analyses meta, couverture esport, patchs décryptés — le flux complet.
					</p>
					<div class="blog-meta">
						<span class="tag tag-red">{posts.length} article{posts.length > 1 ? 's' : ''}</span>
						<span class="tag tag-dark">Mis à jour en continu</span>
					</div>
				</div>
			</section>

			<div class="tfr-stripes -thin" aria-hidden="true"></div>

			<section class="blog-list">
				<div class="container">
					{posts.length === 0 ? (
						<div class="empty card">
							<p>
								<strong>Les premiers articles arrivent dans les jours qui viennent.</strong>
								<br />
								On construit le site en public — reviens vite.
							</p>
						</div>
					) : (
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a class="post card" href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<div class="post-img">
												<Image
													src={post.data.heroImage}
													alt=""
													width={640}
													height={360}
													loading="lazy"
												/>
											</div>
										)}
										<div class="post-body">
											<div class="post-tags">
												{post.data.category && (
													<span class="tag tag-cat" data-cat={post.data.category}>
														{post.data.category}
													</span>
												)}
											</div>
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<div class="post-meta">
												<FormattedDate date={post.data.pubDate} />
												{post.data.author && <span>· par {post.data.author}</span>}
											</div>
										</div>
									</a>
								</li>
							))}
						</ul>
					)}
				</div>
			</section>
		</main>
		<Footer />

		<style>
			main { padding-bottom: 2rem; }

			.blog-hero {
				padding: 5rem 0 3.5rem;
				background: var(--color-blanc);
				border-bottom: 1px solid var(--color-border);
			}

			.blog-title {
				font-size: clamp(3rem, 9vw, 6rem);
				text-transform: uppercase;
				letter-spacing: -0.02em;
				line-height: 0.95;
				margin-top: 1.2rem;
				color: var(--color-noir);
			}

			.blog-title em {
				font-style: normal;
				color: var(--color-rouge);
			}

			.blog-desc {
				margin-top: 1.2rem;
				max-width: 60ch;
				color: var(--color-noir-2);
				font-size: 1rem;
				line-height: 1.65;
			}

			.blog-meta {
				margin-top: 1.5rem;
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}

			.blog-list { padding: 4rem 0; }

			.empty {
				padding: 3rem;
				text-align: center;
				color: var(--color-noir-2);
				font-size: 1rem;
				line-height: 1.7;
				background: var(--color-blanc);
			}

			.empty strong { color: var(--color-rouge); }

			.posts {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.2rem;
			}

			@media (min-width: 768px) {
				.posts { grid-template-columns: repeat(2, 1fr); }
			}

			@media (min-width: 1024px) {
				.posts { grid-template-columns: repeat(3, 1fr); }
			}

			.post {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				overflow: hidden;
				background: var(--color-blanc);
			}

			.post-img {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--color-cream-2);
			}

			.post-img :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.post:hover .post-img :global(img) { transform: scale(1.05); }

			.post-body {
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.post-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.9rem;
			}

			.post-body h3 {
				font-family: var(--font-display);
				font-size: 1.4rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.02em;
				line-height: 1.15;
				color: var(--color-noir);
				margin-bottom: 0.7rem;
				transition: color 0.2s ease;
			}

			.post:hover .post-body h3 { color: var(--color-rouge); }

			.post-body p {
				color: var(--color-noir-2);
				font-size: 0.92rem;
				line-height: 1.55;
				margin-bottom: 1rem;
				flex-grow: 1;
			}

			.post-meta {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--color-gris);
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
