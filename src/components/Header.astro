---
import { NAV_SECTIONS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="tfr-nav">
	<div class="inner">
		<a class="logo" href="/" aria-label={`${SITE_TITLE} — accueil`}>
			<span class="red">The</span>&nbsp;Finals <em>FR</em>
		</a>

		<nav class="links" aria-label="Navigation principale">
			<HeaderLink href="/">Accueil</HeaderLink>
			{NAV_SECTIONS.map((s) => <HeaderLink href={`/${s.slug}/`}>{s.label}</HeaderLink>)}
			<HeaderLink href="/blog/">Tout</HeaderLink>
			<HeaderLink href="/a-propos/">À propos</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.tfr-nav {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(8, 8, 8, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(200, 16, 46, 0.3);
	}

	.inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		min-height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.inner { padding: 0 2rem; }
	}

	.logo {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		color: var(--color-blanc);
		text-transform: uppercase;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.logo .red { color: var(--color-rouge); }

	.logo em {
		font-style: normal;
		color: var(--color-or);
		font-size: 0.65rem;
		font-family: var(--font-mono);
		letter-spacing: 0.12em;
		background: rgba(244, 168, 17, 0.12);
		border: 1px solid rgba(244, 168, 17, 0.35);
		padding: 2px 7px;
		border-radius: 2px;
		line-height: 1;
	}

	.links {
		display: none;
	}

	@media (min-width: 1024px) {
		.links {
			display: flex;
			gap: 0.2rem;
			align-items: center;
		}
	}

	/* Mobile: scroll-wrap nav below logo */
	@media (max-width: 1023px) {
		.inner {
			flex-wrap: wrap;
			padding-top: 0.8rem;
			padding-bottom: 0.8rem;
		}

		.links {
			display: flex;
			order: 3;
			width: 100%;
			gap: 0.15rem;
			overflow-x: auto;
			padding-bottom: 0.15rem;
			scrollbar-width: none;
		}

		.links::-webkit-scrollbar { display: none; }
	}
</style>
