---
import { NAV_SECTIONS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<div class="tfr-curtain" id="tfrCurtain" aria-hidden="true">
	<span class="tfr-curtain-label">Chargement</span>
</div>
<div class="scroll-progress" id="tfrScrollProgress" aria-hidden="true"></div>
<div class="tfr-stripes -thin" aria-hidden="true"></div>

<header class="tfr-nav">
	<div class="inner">
		<a class="logo" href="/" aria-label={`${SITE_TITLE} — accueil`}>
			<span class="mark" aria-hidden="true">
				<span class="mark-letter">M</span>
			</span>
			<span class="name">
				<span class="red">The</span>&nbsp;Finals <em>FR</em>
			</span>
		</a>

		<nav class="links" aria-label="Navigation principale">
			<HeaderLink href="/">Accueil</HeaderLink>
			{NAV_SECTIONS.map((s) => <HeaderLink href={`/${s.slug}/`}>{s.label}</HeaderLink>)}
			<HeaderLink href="/blog/">Tout</HeaderLink>
			<HeaderLink href="/a-propos/">À propos</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.tfr-nav {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(250, 246, 236, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}

	.inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		min-height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.inner { padding: 0 2rem; }
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		flex-shrink: 0;
	}

	/* Signature M-in-circle mark (inspired by The Finals in-game branding) */
	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		background: var(--color-rouge);
		border-radius: 50%;
		color: var(--color-blanc);
		box-shadow: 0 4px 12px -3px rgba(228, 0, 43, 0.4);
	}

	.mark-letter {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 1.1rem;
		letter-spacing: -0.03em;
		line-height: 1;
		margin-top: -1px;
	}

	.name {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		color: var(--color-noir);
		text-transform: uppercase;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		line-height: 1;
	}

	.name .red { color: var(--color-rouge); }

	.name em {
		font-style: normal;
		color: var(--color-rouge);
		font-size: 0.62rem;
		font-family: var(--font-mono);
		letter-spacing: 0.14em;
		border: 1.5px solid var(--color-rouge);
		padding: 3px 6px;
		border-radius: 2px;
		line-height: 1;
	}

	.links {
		display: none;
	}

	@media (min-width: 1024px) {
		.links {
			display: flex;
			gap: 0.1rem;
			align-items: center;
		}
	}

	@media (max-width: 1023px) {
		.inner {
			flex-wrap: wrap;
			padding-top: 0.7rem;
			padding-bottom: 0.5rem;
		}

		.links {
			display: flex;
			order: 3;
			width: 100%;
			gap: 0.1rem;
			overflow-x: auto;
			padding-bottom: 0.2rem;
			scrollbar-width: none;
		}

		.links::-webkit-scrollbar { display: none; }
	}
</style>

<script is:inline>
	(function () {
		if (window.__tfrScrollInit) return;
		window.__tfrScrollInit = true;
		const get = () => document.getElementById('tfrScrollProgress');
		let raf = 0;
		const update = () => {
			const bar = get();
			if (!bar) { raf = 0; return; }
			const doc = document.documentElement;
			const max = doc.scrollHeight - window.innerHeight;
			const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
			bar.style.width = (ratio * 100).toFixed(2) + '%';
			raf = 0;
		};
		const onScroll = () => {
			if (raf) return;
			raf = requestAnimationFrame(update);
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll, { passive: true });
		update();
	})();
</script>

<script is:inline>
	/* ================================================================= */
	/*  Page transition — "Broadcast curtain"                            */
	/*  JS-driven transform (no CSS keyframes) for rock-solid timing.    */
	/*  Intentionally ignores prefers-reduced-motion — user requested.   */
	/* ================================================================= */
	(function () {
		if (window.__tfrCurtainInit) return;
		window.__tfrCurtainInit = true;

		const curtain = document.getElementById('tfrCurtain');
		if (!curtain) return;

		const FLAG = 'tfr-curtain-navigated';
		const COVER_MS = 700;
		const UNCOVER_MS = 700;

		/* -------------------- Intro on arrival -------------------- */
		const playUncover = () => {
			/* Curtain starts fully covering the viewport. */
			curtain.classList.remove('is-uncover');
			curtain.classList.add('is-cover');
			/* Force reflow so the browser registers the "covered" state. */
			void curtain.offsetHeight;
			/* Next frame: trigger the uncover. */
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					curtain.classList.remove('is-cover');
					curtain.classList.add('is-uncover');
				});
			});
			/* Cleanup after the transition completes. */
			window.setTimeout(() => {
				curtain.classList.remove('is-cover', 'is-uncover');
				document.body.classList.remove('is-navigating');
			}, UNCOVER_MS + 80);
		};

		try {
			if (sessionStorage.getItem(FLAG) === '1') {
				sessionStorage.removeItem(FLAG);
				document.body.classList.add('is-navigating');
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', playUncover, { once: true });
				} else {
					playUncover();
				}
			}
		} catch (e) {}

		/* Back/forward cache restore — skip animation, reset state. */
		window.addEventListener('pageshow', (e) => {
			if (e.persisted) {
				curtain.classList.remove('is-cover', 'is-uncover');
				document.body.classList.remove('is-navigating');
			}
		});

		/* -------------------- Click interception -------------------- */
		const shouldIntercept = (a, event) => {
			if (!a || !a.getAttribute('href')) return false;
			if (a.target && a.target !== '' && a.target !== '_self') return false;
			if (a.hasAttribute('download')) return false;
			if (a.getAttribute('data-no-transition') !== null) return false;
			if (event.defaultPrevented) return false;
			if (event.button !== undefined && event.button !== 0) return false;
			if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return false;

			const raw = a.getAttribute('href');
			if (!raw || raw.startsWith('javascript:') || raw.startsWith('mailto:') || raw.startsWith('tel:')) {
				return false;
			}

			let url;
			try {
				url = new URL(a.href, location.href);
			} catch (err) {
				return false;
			}
			if (url.origin !== location.origin) return false;
			/* Pure anchor link — let browser scroll smoothly. */
			if (
				url.pathname === location.pathname &&
				url.search === location.search &&
				url.hash &&
				url.hash !== location.hash
			) {
				return false;
			}
			/* Exact same URL — no-op. */
			if (url.href === location.href) return false;
			return url.href;
		};

		document.addEventListener(
			'click',
			(event) => {
				const a = event.target && event.target.closest && event.target.closest('a[href]');
				const target = shouldIntercept(a, event);
				if (!target) return;

				event.preventDefault();
				try { sessionStorage.setItem(FLAG, '1'); } catch (e) {}

				document.body.classList.add('is-navigating');
				curtain.classList.remove('is-uncover');
				void curtain.offsetHeight;
				requestAnimationFrame(() => {
					curtain.classList.add('is-cover');
				});

				let navigated = false;
				const go = () => {
					if (navigated) return;
					navigated = true;
					window.location.href = target;
				};

				/* Navigate once the cover transition completes. */
				window.setTimeout(go, COVER_MS + 60);
			},
			true
		);
	})();
</script>
