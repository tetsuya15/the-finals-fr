---
import { NAV_SECTIONS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<div class="scroll-progress" id="tfrScrollProgress" aria-hidden="true"></div>
<div class="tfr-stripes -thin" aria-hidden="true"></div>

<header class="tfr-nav">
	<div class="inner">
		<a class="logo" href="/" aria-label={`${SITE_TITLE} — accueil`}>
			<span class="mark" aria-hidden="true">
				<span class="mark-letter">TFFR</span>
			</span>
			<span class="name">
				<span class="red">The</span>&nbsp;Finals <em>FR</em>
			</span>
		</a>

		<nav class="links" aria-label="Navigation principale">
			<HeaderLink href="/">Accueil</HeaderLink>
			{NAV_SECTIONS.map((s) => <HeaderLink href={`/${s.slug}/`}>{s.label}</HeaderLink>)}
			<HeaderLink href="/a-propos/">À propos</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.tfr-nav {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(250, 246, 236, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}

	.inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		min-height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.inner { padding: 0 2rem; }
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		flex-shrink: 0;
	}

	/* Signature round mark for The Finals France */
	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		background: var(--color-rouge);
		border-radius: 50%;
		color: var(--color-blanc);
		box-shadow: 0 4px 12px -3px rgba(228, 0, 43, 0.4);
	}

	.mark-letter {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 0.66rem;
		letter-spacing: 0.02em;
		line-height: 1;
		margin-top: 0;
	}

	.name {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		color: var(--color-noir);
		text-transform: uppercase;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		line-height: 1;
	}

	.name .red { color: var(--color-rouge); }

	.name em {
		font-style: normal;
		color: var(--color-rouge);
		font-size: 0.62rem;
		font-family: var(--font-mono);
		letter-spacing: 0.14em;
		border: 1.5px solid var(--color-rouge);
		padding: 3px 6px;
		border-radius: 2px;
		line-height: 1;
	}

	.links {
		display: none;
	}

	@media (min-width: 1024px) {
		.links {
			display: flex;
			gap: 0.1rem;
			align-items: center;
		}
	}

	@media (max-width: 1023px) {
		.inner {
			flex-wrap: wrap;
			padding-top: 0.7rem;
			padding-bottom: 0.5rem;
		}

		.links {
			display: flex;
			order: 3;
			width: 100%;
			gap: 0.1rem;
			overflow-x: auto;
			padding-bottom: 0.2rem;
			scrollbar-width: none;
		}

		.links::-webkit-scrollbar { display: none; }
	}
</style>

<script is:inline>
	(function () {
		if (window.__tfrScrollInit) return;
		window.__tfrScrollInit = true;
		const get = () => document.getElementById('tfrScrollProgress');
		let raf = 0;
		const update = () => {
			const bar = get();
			if (!bar) { raf = 0; return; }
			const doc = document.documentElement;
			const max = doc.scrollHeight - window.innerHeight;
			const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
			bar.style.width = (ratio * 100).toFixed(2) + '%';
			raf = 0;
		};
		const onScroll = () => {
			if (raf) return;
			raf = requestAnimationFrame(update);
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll, { passive: true });
		update();
	})();
</script>

