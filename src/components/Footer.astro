---
import { NAV_SECTIONS, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="tfr-footer">
	<div class="tfr-stripes" aria-hidden="true"></div>

	<div class="body">
		<div class="grid">
			<div class="brand">
				<a class="logo" href="/">
					<span class="mark" aria-hidden="true"><span>M</span></span>
					<span class="name"><span class="red">The</span>&nbsp;Finals <em>FR</em></span>
				</a>
				<p class="desc">
					Site communautaire francophone 100% dédié au compétitif sur The Finals —
					meta, esport, wiki, actus et lore. Construit en public, relu à la main
					avant chaque publication.
				</p>
				<div class="social">
					<a class="chip" href="https://github.com/tetsuya15" target="_blank" rel="noopener">GitHub</a>
					<a class="chip" href="/rss.xml">RSS</a>
				</div>
			</div>

			<div class="col">
				<h4>Sections</h4>
				<ul>
					{NAV_SECTIONS.map((s) => (
						<li><a href={`/${s.slug}/`}>{s.label}</a></li>
					))}
				</ul>
			</div>

			<div class="col">
				<h4>Le site</h4>
				<ul>
					<li><a href="/">Accueil</a></li>
					<li><a href="/a-propos/">À propos</a></li>
					<li><a href="/rss.xml">Flux RSS</a></li>
				</ul>
			</div>

			<div class="col">
				<h4>Ressources</h4>
				<ul>
					<li><a href="https://www.reachthefinals.com" target="_blank" rel="noopener">Site officiel</a></li>
					<li><a href="https://liquipedia.net/thefinals" target="_blank" rel="noopener">Liquipedia</a></li>
					<li><a href="https://www.reddit.com/r/thefinals/" target="_blank" rel="noopener">Reddit</a></li>
				</ul>
			</div>
		</div>

		<div class="tfr-signature" aria-hidden="true">
			<div class="tfr-tower">
				<svg class="tower-svg" viewBox="0 0 60 140" preserveAspectRatio="xMidYMid meet">
					<g class="tower-waves">
						<circle class="wave wave-1" cx="30" cy="18" r="5" />
						<circle class="wave wave-2" cx="30" cy="18" r="5" />
						<circle class="wave wave-3" cx="30" cy="18" r="5" />
					</g>
					<circle class="tower-dot" cx="30" cy="18" r="3.5" />
					<line class="tower-line" x1="30" y1="22" x2="30" y2="132" />
					<circle class="tower-signal" cx="30" cy="132" r="1.8" />
					<line class="tower-base" x1="18" y1="132" x2="42" y2="132" />
				</svg>
			</div>
			<p class="tfr-signature-text">
				<span class="sig-kicker">EN DIRECT —</span>
				<span class="sig-main">L'Arène est <em>à toi</em>.</span>
			</p>
		</div>

		<div class="bottom">
			<p class="copy">
				&copy; {today.getFullYear()} {SITE_TITLE} — Site communautaire<br />
				Articles sous licence
				<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.fr" target="_blank" rel="noopener">CC BY-NC-SA 4.0</a>
				— code sous licence MIT.
			</p>
			<p class="disclaimer">
				THE FINALS™ est une marque déposée d'Embark Studios. Ce fan site est indépendant
				et n'est pas affilié, approuvé ou sponsorisé par Embark Studios AB ou Nexon.
			</p>
		</div>
	</div>
</footer>

<style>
	.tfr-footer {
		margin-top: 6rem;
		background: var(--color-cream-2);
		border-top: 1px solid var(--color-border);
	}

	.body {
		padding: 3.5rem 1.5rem 1.5rem;
	}

	@media (min-width: 768px) {
		.body { padding: 3.5rem 2rem 1.5rem; }
	}

	.grid {
		max-width: 1200px;
		margin: 0 auto 3rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	@media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (min-width: 1024px) { .grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; } }

	.brand .logo {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}

	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		background: var(--color-rouge);
		color: var(--color-blanc);
		border-radius: 50%;
	}

	.mark span {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 1rem;
		line-height: 1;
		margin-top: -1px;
	}

	.brand .name {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		color: var(--color-noir);
		text-transform: uppercase;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.brand .name .red { color: var(--color-rouge); }

	.brand .name em {
		font-style: normal;
		color: var(--color-rouge);
		font-size: 0.56rem;
		font-family: var(--font-mono);
		letter-spacing: 0.12em;
		border: 1.5px solid var(--color-rouge);
		padding: 2px 5px;
		border-radius: 2px;
		line-height: 1;
	}

	.desc {
		font-size: 0.9rem;
		color: var(--color-gris);
		line-height: 1.65;
		margin-bottom: 1.25rem;
		max-width: 40ch;
	}

	.social {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.chip {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--color-border);
		color: var(--color-gris);
		background: var(--color-blanc);
		border-radius: 1px;
		transition: all 0.2s ease;
	}

	.chip:hover {
		border-color: var(--color-rouge);
		color: var(--color-rouge);
		background: var(--color-rouge-soft);
	}

	.col h4 {
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-noir);
		margin-bottom: 1rem;
	}

	.col ul { list-style: none; padding: 0; margin: 0; }
	.col li { margin-bottom: 0.55rem; }

	.col a {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		color: var(--color-gris);
		transition: color 0.2s ease;
	}

	.col a:hover { color: var(--color-rouge); }

	.bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.copy, .disclaimer {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		line-height: 1.6;
		letter-spacing: 0.05em;
	}

	.copy { color: var(--color-gris); }

	.copy a {
		color: var(--color-noir);
		border-bottom: 1px solid transparent;
		transition: all 0.2s ease;
	}

	.copy a:hover {
		color: var(--color-rouge);
		border-bottom-color: var(--color-rouge);
	}

	.disclaimer {
		color: var(--color-gris-2);
		max-width: 420px;
		text-align: right;
	}

	@media (max-width: 768px) { .disclaimer { text-align: left; } }

	/* -------------------------------------------------------------------------- */
	/*  Broadcast signature — inspired by magnitude.be candle/tagline             */
	/* -------------------------------------------------------------------------- */

	.tfr-signature {
		max-width: 1200px;
		margin: 0 auto 2rem;
		padding: 3.5rem 1.5rem 3rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		border-top: 1px solid var(--color-border);
		position: relative;
	}

	.tfr-tower {
		width: 60px;
		height: 140px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.tower-svg {
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.tower-line {
		stroke: var(--color-noir);
		stroke-width: 1;
		opacity: 0.35;
	}

	.tower-base {
		stroke: var(--color-noir);
		stroke-width: 1.5;
		opacity: 0.35;
	}

	.tower-dot {
		fill: var(--color-rouge);
		transform-origin: 30px 18px;
		filter: drop-shadow(0 0 3px rgba(228, 0, 43, 0.55));
		animation: tfr-dot-breath 2s ease-in-out infinite;
	}

	.wave {
		fill: none;
		stroke: var(--color-rouge);
		stroke-width: 1.2;
		transform-origin: 30px 18px;
		transform-box: fill-box;
		opacity: 0;
		animation: tfr-wave 3s cubic-bezier(0.2, 0.6, 0.4, 1) infinite;
	}

	.wave-1 { animation-delay: 0s; }
	.wave-2 { animation-delay: 1s; }
	.wave-3 { animation-delay: 2s; }

	.tower-signal {
		fill: var(--color-rouge);
		filter: drop-shadow(0 0 2px rgba(228, 0, 43, 0.6));
		animation: tfr-signal-rise 2.6s ease-in infinite;
	}

	@keyframes tfr-dot-breath {
		0%, 100% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.45); opacity: 0.65; }
	}

	@keyframes tfr-wave {
		0% { transform: scale(0.2); opacity: 0.8; }
		70% { opacity: 0.2; }
		100% { transform: scale(3.6); opacity: 0; }
	}

	@keyframes tfr-signal-rise {
		0% { transform: translateY(0); opacity: 0; }
		15% { opacity: 1; }
		85% { opacity: 1; }
		100% { transform: translateY(-110px); opacity: 0; }
	}

	.tfr-signature-text {
		text-align: center;
		line-height: 1.2;
		margin: 0;
	}

	.sig-kicker {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-rouge);
		margin-bottom: 0.55rem;
		position: relative;
	}

	.sig-kicker::before {
		content: '';
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-rouge);
		margin-right: 0.5em;
		vertical-align: middle;
		box-shadow: 0 0 0 0 rgba(228, 0, 43, 0.6);
		animation: tfr-pin-pulse 1.8s ease-in-out infinite;
	}

	@keyframes tfr-pin-pulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(228, 0, 43, 0.6); opacity: 1; }
		50% { box-shadow: 0 0 0 6px rgba(228, 0, 43, 0); opacity: 0.55; }
	}

	.sig-main {
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 3.2vw, 2.4rem);
		font-weight: 900;
		letter-spacing: 0.01em;
		text-transform: uppercase;
		color: var(--color-noir);
		display: block;
	}

	.sig-main em {
		font-style: italic;
		color: var(--color-rouge);
	}

	@media (prefers-reduced-motion: reduce) {
		.tower-dot, .wave, .tower-signal, .sig-kicker::before {
			animation: none;
		}
	}
</style>
