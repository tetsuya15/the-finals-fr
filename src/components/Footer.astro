---
import { NAV_SECTIONS, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="tfr-footer">
	<div class="tfr-stripes" aria-hidden="true"></div>

	<div class="body">
		<div class="grid">
			<div class="brand">
				<a class="logo" href="/">
					<span class="mark" aria-hidden="true"><span>M</span></span>
					<span class="name"><span class="red">The</span>&nbsp;Finals <em>FR</em></span>
				</a>
				<p class="desc">
					Site communautaire francophone 100% dédié au compétitif sur The Finals —
					meta, esport, wiki, actus et lore. Construit en public, relu à la main
					avant chaque publication.
				</p>
				<div class="social">
					<a class="chip" href="https://github.com/tetsuya15" target="_blank" rel="noopener">GitHub</a>
					<a class="chip" href="/rss.xml">RSS</a>
				</div>
			</div>

			<div class="col">
				<h4>Sections</h4>
				<ul>
					{NAV_SECTIONS.map((s) => (
						<li><a href={`/${s.slug}/`}>{s.label}</a></li>
					))}
				</ul>
			</div>

			<div class="col">
				<h4>Le site</h4>
				<ul>
					<li><a href="/">Accueil</a></li>
					<li><a href="/a-propos/">À propos</a></li>
					<li><a href="/rss.xml">Flux RSS</a></li>
				</ul>
			</div>

			<div class="col">
				<h4>Ressources</h4>
				<ul>
					<li><a href="https://www.reachthefinals.com" target="_blank" rel="noopener">Site officiel</a></li>
					<li><a href="https://liquipedia.net/thefinals" target="_blank" rel="noopener">Liquipedia</a></li>
					<li><a href="https://www.reddit.com/r/thefinals/" target="_blank" rel="noopener">Reddit</a></li>
				</ul>
			</div>
		</div>

		<div class="tfr-cashout-reveal" data-reveal aria-hidden="true">
			<div class="cashout-inner">
				<svg class="cashout-svg" viewBox="0 0 400 400" preserveAspectRatio="xMidYMid meet">
					<defs>
						<clipPath id="cashout-mask">
							<circle cx="200" cy="200" r="90" />
						</clipPath>
					</defs>
					<circle class="cashout-outer" cx="200" cy="200" r="90" />
					<g class="cashout-rays">
						<line x1="200" y1="105" x2="200" y2="60" />
						<line x1="200" y1="295" x2="200" y2="340" />
						<line x1="105" y1="200" x2="60" y2="200" />
						<line x1="295" y1="200" x2="340" y2="200" />
						<line x1="132" y1="132" x2="100" y2="100" />
						<line x1="268" y1="268" x2="300" y2="300" />
						<line x1="268" y1="132" x2="300" y2="100" />
						<line x1="132" y1="268" x2="100" y2="300" />
					</g>
					<g class="cashout-moon" clip-path="url(#cashout-mask)">
						<circle class="moon-disc" cx="200" cy="200" r="75" />
						<text class="moon-letter" x="200" y="225" text-anchor="middle">M</text>
					</g>
				</svg>
			</div>
			<p class="cashout-caption">
				<span class="cap-kicker">Le Cashout</span>
				<strong class="cap-main">est à <em>toi</em>.</strong>
			</p>
		</div>

		<div class="bottom">
			<p class="copy">
				&copy; {today.getFullYear()} {SITE_TITLE} — Site communautaire<br />
				Articles sous licence
				<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.fr" target="_blank" rel="noopener">CC BY-NC-SA 4.0</a>
				— code sous licence MIT.
			</p>
			<p class="disclaimer">
				THE FINALS™ est une marque déposée d'Embark Studios. Ce fan site est indépendant
				et n'est pas affilié, approuvé ou sponsorisé par Embark Studios AB ou Nexon.
			</p>
		</div>
	</div>
</footer>

<style>
	.tfr-footer {
		margin-top: 6rem;
		background: var(--color-cream-2);
		border-top: 1px solid var(--color-border);
	}

	.body {
		padding: 3.5rem 1.5rem 1.5rem;
	}

	@media (min-width: 768px) {
		.body { padding: 3.5rem 2rem 1.5rem; }
	}

	.grid {
		max-width: 1200px;
		margin: 0 auto 3rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	@media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (min-width: 1024px) { .grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; } }

	.brand .logo {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}

	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		background: var(--color-rouge);
		color: var(--color-blanc);
		border-radius: 50%;
	}

	.mark span {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 1rem;
		line-height: 1;
		margin-top: -1px;
	}

	.brand .name {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		color: var(--color-noir);
		text-transform: uppercase;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.brand .name .red { color: var(--color-rouge); }

	.brand .name em {
		font-style: normal;
		color: var(--color-rouge);
		font-size: 0.56rem;
		font-family: var(--font-mono);
		letter-spacing: 0.12em;
		border: 1.5px solid var(--color-rouge);
		padding: 2px 5px;
		border-radius: 2px;
		line-height: 1;
	}

	.desc {
		font-size: 0.9rem;
		color: var(--color-gris);
		line-height: 1.65;
		margin-bottom: 1.25rem;
		max-width: 40ch;
	}

	.social {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.chip {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--color-border);
		color: var(--color-gris);
		background: var(--color-blanc);
		border-radius: 1px;
		transition: all 0.2s ease;
	}

	.chip:hover {
		border-color: var(--color-rouge);
		color: var(--color-rouge);
		background: var(--color-rouge-soft);
	}

	.col h4 {
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-noir);
		margin-bottom: 1rem;
	}

	.col ul { list-style: none; padding: 0; margin: 0; }
	.col li { margin-bottom: 0.55rem; }

	.col a {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		color: var(--color-gris);
		transition: color 0.2s ease;
	}

	.col a:hover { color: var(--color-rouge); }

	.bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.copy, .disclaimer {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		line-height: 1.6;
		letter-spacing: 0.05em;
	}

	.copy { color: var(--color-gris); }

	.copy a {
		color: var(--color-noir);
		border-bottom: 1px solid transparent;
		transition: all 0.2s ease;
	}

	.copy a:hover {
		color: var(--color-rouge);
		border-bottom-color: var(--color-rouge);
	}

	.disclaimer {
		color: var(--color-gris-2);
		max-width: 420px;
		text-align: right;
	}

	@media (max-width: 768px) { .disclaimer { text-align: left; } }

	/* -------------------------------------------------------------------------- */
	/*  Cashout reveal — inspired by magnitude.be "maan-zon" scroll animation     */
	/* -------------------------------------------------------------------------- */

	.tfr-cashout-reveal {
		max-width: 1200px;
		margin: 0 auto 2rem;
		padding: 4.5rem 1.5rem 3.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.75rem;
		border-top: 1px solid var(--color-border);
		position: relative;
	}

	.cashout-inner {
		width: clamp(120px, 14vw, 180px);
		height: clamp(120px, 14vw, 180px);
		position: relative;
	}

	.cashout-svg {
		width: 100%;
		height: 100%;
		overflow: visible;
		display: block;
	}

	/* Outer static circle — always visible, sets the stage */
	.cashout-outer {
		fill: none;
		stroke: rgba(23, 23, 23, 0.28);
		stroke-width: 2.4;
	}

	/* Rays — hidden by default, emerge when active */
	.cashout-rays line {
		stroke: var(--color-noir);
		stroke-width: 3;
		stroke-linecap: round;
		transform-origin: 200px 200px;
		transform-box: view-box;
		transform: scale(0.05);
		opacity: 0;
		transition:
			transform 0.55s cubic-bezier(0.2, 0.9, 0.3, 1.2),
			opacity 0.35s ease-out;
	}

	/* Moon (the "M" cashbox) — slides in from the left */
	.cashout-moon {
		transform: translateX(-260px);
		opacity: 0;
		transition:
			transform 1s cubic-bezier(0.3, 0.8, 0.2, 1),
			opacity 0.4s ease-out 0.15s;
	}

	.moon-disc {
		fill: var(--color-noir);
	}

	.moon-letter {
		fill: #fff;
		font-family: var(--font-display, 'Archivo', sans-serif);
		font-size: 82px;
		font-weight: 900;
		font-style: italic;
		letter-spacing: -0.02em;
		dominant-baseline: middle;
	}

	/* -------- Activated state (when the block enters the viewport) ---------- */

	.tfr-cashout-reveal.is-active .cashout-moon {
		transform: translateX(0);
		opacity: 1;
	}

	.tfr-cashout-reveal.is-active .cashout-rays line {
		opacity: 1;
		transform: scale(1);
	}

	/* Staggered reveal of the 8 rays, triggered after the moon arrives */
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(1) { transition-delay: 1.05s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(2) { transition-delay: 1.10s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(3) { transition-delay: 1.15s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(4) { transition-delay: 1.20s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(5) { transition-delay: 1.25s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(6) { transition-delay: 1.30s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(7) { transition-delay: 1.35s; }
	.tfr-cashout-reveal.is-active .cashout-rays line:nth-child(8) { transition-delay: 1.40s; }

	/* Slow continuous rotation of the rays after the reveal is done */
	.tfr-cashout-reveal.is-active .cashout-rays {
		animation: cashout-spin 40s linear infinite;
		animation-delay: 1.9s;
		transform-origin: 200px 200px;
		transform-box: view-box;
	}

	@keyframes cashout-spin {
		to { transform: rotate(360deg); }
	}

	/* --------- Caption under the animation ---------------------------------- */

	.cashout-caption {
		text-align: center;
		line-height: 1.15;
		margin: 0;
		opacity: 0;
		transform: translateY(14px);
		transition: opacity 0.6s ease-out 0.8s, transform 0.6s ease-out 0.8s;
	}

	.tfr-cashout-reveal.is-active .cashout-caption {
		opacity: 1;
		transform: translateY(0);
	}

	.cap-kicker {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--color-rouge);
		margin-bottom: 0.6rem;
	}

	.cap-main {
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 3.2vw, 2.4rem);
		font-weight: 900;
		letter-spacing: 0.01em;
		text-transform: uppercase;
		color: var(--color-noir);
		display: block;
	}

	.cap-main em {
		font-style: italic;
		color: var(--color-rouge);
	}

	/* Accessibility: reduce motion */
	@media (prefers-reduced-motion: reduce) {
		.cashout-moon,
		.cashout-rays line,
		.cashout-caption {
			transition: none;
		}
		.tfr-cashout-reveal.is-active .cashout-rays {
			animation: none;
		}
	}
</style>

<script>
	// Scroll-linked reveal for the cashout animation in the footer.
	// Uses IntersectionObserver so the animation only fires the first time
	// the block becomes partially visible — feels like "entering the frame"
	// exactly like the magnitude.be footer.
	(() => {
		const block = document.querySelector('.tfr-cashout-reveal');
		if (!block) return;

		if (!('IntersectionObserver' in window) ||
			window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			block.classList.add('is-active');
			return;
		}

		const io = new IntersectionObserver((entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					block.classList.add('is-active');
					io.disconnect();
					break;
				}
			}
		}, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });

		io.observe(block);
	})();
</script>
